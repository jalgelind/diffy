import { Button, CheckBox, ListView, ScrollView, LineEdit } from "std-widgets.slint";

// ---- shared data structures (mirrored by generated C++ types) --------------

export struct DiffSpan {
    text: string,
    color: color,
    bold: bool,
}

export struct DiffRowData {
    is-header: bool,
    header: string,
    old-no: string,
    new-no: string,
    left-spans: [DiffSpan],
    left-text: string,   // full line text, for word-wrap rendering
    left-cols: int,      // display width in columns (to decide if it fits unwrapped)
    left-bg: color,
    left-present: bool,
    right-spans: [DiffSpan],
    right-text: string,
    right-cols: int,
    right-bg: color,
    right-present: bool,
}

export struct FileEntry {
    path: string,
    status: string,
    name: string,   // basename, kept visible when the row is too narrow
    dir: string,    // leading directory (elided first)
    staged: bool,
    is-section: bool,  // a non-selectable section/group header row
    depth: int,        // indent level (folder grouping)
}

export struct CommitEntry {
    oid: string,
    short-oid: string,
    summary: string,
}

// ---- option-bar state, shared with C++ -------------------------------------

export global DiffOptions {
    in-out property <bool> side-by-side: true;
    in-out property <bool> word-wrap: false;
    in-out property <bool> show-line-numbers: true;
    in-out property <bool> ignore-whitespace: false;
    in-out property <bool> token-granularity: true;
    in-out property <bool> syntax-highlight: true;
    in-out property <int> context-lines: 3;
    in-out property <int> algorithm: 0;  // 0 patience, 1 myers-greedy, 2 myers-linear

    callback relayout();  // layout-only change (cheap)
    callback rediff();    // needs a re-diff
}

// ---- everything C++ drives -------------------------------------------------

export global Backend {
    in property <[string]> repo-names;
    in property <[FileEntry]> files;
    in property <[CommitEntry]> commits;
    in property <bool> more-commits: false;     // history has more than is loaded
    in property <bool> loading-commits: false;  // a load-more is in flight
    in property <[DiffRowData]> rows;

    // Persisted layout, two-way: dragged in the UI, read back on exit to save.
    in-out property <length> sidebar-width: 300px;
    in-out property <length> commits-panel-height: 150px;
    // Keyboard-navigation selection (row index in each list, -1 = none). Driven by
    // C++ for key nav and by clicks; the lists scroll the row into view on change.
    in-out property <int> file-sel-index: -1;
    in-out property <int> commit-sel-index: -1;

    in property <[string]> branch-names;   // local branches for the checkout combo
    in property <int> staged-count: 0;     // staged files (enables Commit)
    in-out property <bool> group-by-folder: false;  // changes-list grouping mode
    in-out property <string> confirm-discard: "";  // path pending a discard confirm
    in property <string> current-file: "";
    in property <string> diff-note: "";  // why the file isn't diffed (binary/large)
    in-out property <int> diff-scroll-row: -1;  // jump the diff to this model row
    // Find-in-diff state.
    in-out property <bool> show-find: false;
    in property <int> find-count: 0;          // total matches
    in property <int> find-current: 0;        // 1-based index of current match
    in-out property <int> find-current-row: -1;  // model row to highlight
    in property <string> branch: "";
    in property <string> status-text: "Open a repository to begin.";
    in property <bool> loading: false;  // a repo open is in progress
    in property <int> max-cols: 0;  // longest line in chars, for horizontal scroll

    in-out property <string> mono-font: "Menlo";
    in-out property <int> font-size: 13;
    // Settings panel state + values it edits.
    in-out property <bool> show-settings: false;
    in-out property <int> tab-width: 4;
    in property <[string]> font-choices;   // curated monospace families (per-OS)
    in property <[string]> theme-names;     // theme .conf files found on disk
    in-out property <string> theme-name;    // currently applied theme
    in property <color> bg: #1e1e1e;
    in property <color> panel-bg: #252526;
    in property <color> fg: #d4d4d4;
    in property <color> gutter-fg: #6e7681;
    in property <color> accent: #0e639c;
    in property <color> on-accent: white;  // contrasts with accent (set per theme)
    in property <color> header-bg: #2d2d30;
    in property <color> header-fg: #9cdcfe;
    in property <color> divider: #3c3c3c;     // separators / borders
    in property <color> selection: #094771;   // selected list row
    in property <color> hover: #2a2d2e;        // hovered list row

    callback open-repo(string);
    callback browse-repo();
    callback select-repo-index(int);
    callback select-file(string);
    callback select-commit(string);
    callback load-more-commits();
    callback load-all-commits();
    callback filter-files(string);  // substring filter for the changes list
    callback navigate(string);      // keyboard nav: "up"|"down"|"tab"|"activate"
    callback refresh();             // re-scan status + reload commits
    callback set-tab-width(int);    // re-render with a new tab stop
    callback set-theme(string);     // load + apply a theme by name, live
    callback find(string);          // run a find-in-diff query
    callback find-next();
    callback find-prev();
    callback find-close();
    callback stage-file(string);
    callback unstage-file(string);
    callback discard-file(string);  // destructive — confirm in the UI first
    callback commit(string, bool);  // message, amend
    callback checkout-branch(string);
    callback auto-refresh();        // periodic background status re-scan
    callback regroup-files();       // re-render the changes list after a grouping change
}

// ---- icons -----------------------------------------------------------------

// A monochrome (Lucide) icon, tinted to the theme. Override `colorize`/`size`
// at the call site; set `source` with @image-url("icons/<name>.svg").
// The icon is a fixed-width wrapper that stretches to its layout cell's height
// and centers the glyph inside it, so it sits vertically centered next to text.
component Icon inherits Rectangle {
    in property <length> size: 16px;
    in property <image> source;
    in property <color> colorize: Backend.fg;
    width: size;
    Image {
        width: root.size;
        height: root.size;
        image-fit: contain;
        source: root.source;
        colorize: root.colorize;
    }
}

// File-status badge: picks a Lucide circle glyph + colour from the status code.
component StatusIcon inherits Rectangle {
    in property <string> status;
    width: 15px;
    Image {
        width: 15px;
        height: 15px;
        image-fit: contain;
        source: status == "D" ? @image-url("icons/circle-minus.svg")
              : status == "M" ? @image-url("icons/circle-dot.svg")
              : status == "?" ? @image-url("icons/circle-help.svg")
              : (status == "A" || status == "R" || status == "C") ? @image-url("icons/circle-plus.svg")
              : @image-url("icons/circle-dot.svg");
        colorize: status == "D" ? #f48771
                : status == "M" ? #e2c08d
                : status == "?" ? #73c991
                : status == "A" ? #73c991
                : Backend.accent;
    }
}

// ---- one diff line ---------------------------------------------------------

component DiffCellView inherits Rectangle {
    in property <[DiffSpan]> spans;
    in property <string> full-text;
    in property <int> cols;            // line width in display columns
    in property <color> bg;
    in property <bool> wrap;
    in property <length> avail-width;  // the cell's own width (set by the row)

    // Approximate monospace advance, used to decide whether a line fits on one
    // line. Only lines that genuinely overflow fall back to the (single-colour)
    // wrapped Text; everything else keeps its per-token syntax/diff colours.
    property <length> char-w: Backend.font-size * 0.62px;
    property <bool> overflow: (root.cols * char-w) > (root.avail-width - 8px);
    property <bool> wrapping: root.wrap && overflow && root.avail-width > 12px;

    // The wrapped text's actual height (0 unless this cell is actually wrapping),
    // so the row only grows for genuinely-wrapped lines.
    out property <length> wrapped-height: wrapping ? wt.height : 0px;
    background: bg;
    clip: !wrapping;  // wrapped cells grow vertically; single lines clip at the edge

    // Overflowing + wrap on: one flowing Text with an explicit width. Per-token
    // colour is traded for wrapping; the add/remove background still shows.
    wt := Text {
        visible: wrapping;
        x: 6px;
        width: max(1px, root.avail-width - 10px);
        text: root.full-text;
        color: Backend.fg;
        font-family: Backend.mono-font;
        font-size: Backend.font-size * 1px;
        wrap: word-wrap;
    }

    // Otherwise: highlighted spans on a single line (clipped at the cell edge).
    if !wrapping : HorizontalLayout {
        alignment: start;
        padding-left: 6px;
        for span in spans : Text {
            text: span.text;
            color: span.color;
            font-family: Backend.mono-font;
            font-size: Backend.font-size * 1px;
            font-weight: span.bold ? 700 : 400;
            vertical-alignment: center;
        }
    }
}

component LineNo inherits Text {
    width: 48px;
    color: Backend.gutter-fg;
    font-family: Backend.mono-font;
    font-size: Backend.font-size * 1px;
    horizontal-alignment: right;
    vertical-alignment: center;
}

// One full diff row used as a (virtualized) ListView delegate. Side-by-side
// shows both cells with a centred 1px divider; unified shows one cell with both
// line-number gutters. Both cells live in the same HorizontalLayout, so they
// share a height automatically — wrapped lines stay aligned across the divider.
component DiffRow inherits Rectangle {
    in property <DiffRowData> rowdata;
    in property <bool> highlight: false;  // current find match
    // Explicit per-cell width (one gutter per shown line-number column, minus the
    // 1px divider in side-by-side). Giving cells a definite width is what lets
    // the wrapped Text report a real height-for-width.
    property <length> gut: DiffOptions.show-line-numbers ? 48px : 0px;
    property <bool> sxs: DiffOptions.side-by-side;
    property <length> cellw: max(10px, sxs
        ? (root.width - 2 * gut - 1px) / 2
        : (root.width - 2 * gut));
    // ListView delegates need a concrete height. Fixed line height normally;
    // when word-wrap is on, grow to the tallest cell's actual wrapped height.
    height: rowdata.is-header
        ? Backend.font-size * 1.6px
        : (DiffOptions.word-wrap
            ? max(Backend.font-size * 1.6px, leftcell.wrapped-height, rightcell.wrapped-height)
            : Backend.font-size * 1.6px);

    if rowdata.is-header : Rectangle {
        height: Backend.font-size * 1.6px;
        background: Backend.header-bg;
        Rectangle { x: 0; width: 3px; background: Backend.accent; }
        Text {
            x: 12px;
            text: rowdata.header;
            color: Backend.header-fg;
            font-family: Backend.mono-font;
            font-size: Backend.font-size * 1px;
            vertical-alignment: center;
        }
    }

    // All cells/gutters are always present (widths collapse to 0 when unused) so
    // their heights stay referenceable from the row height binding above.
    body := HorizontalLayout {
        visible: !rowdata.is-header;
        spacing: 0px;
        LineNo { text: rowdata.old-no; visible: DiffOptions.show-line-numbers; }
        // unified shows both line numbers in the left gutter
        LineNo {
            text: rowdata.new-no;
            width: (!sxs && DiffOptions.show-line-numbers) ? 48px : 0px;
            visible: !sxs && DiffOptions.show-line-numbers;
        }
        leftcell := DiffCellView {
            width: cellw;
            avail-width: cellw;
            spans: rowdata.left-spans;
            full-text: rowdata.left-text;
            cols: rowdata.left-cols;
            bg: rowdata.left-bg;
            wrap: DiffOptions.word-wrap;
        }
        Rectangle { width: sxs ? 1px : 0px; background: Backend.divider; }
        LineNo {
            text: rowdata.new-no;
            width: (sxs && DiffOptions.show-line-numbers) ? 48px : 0px;
            visible: sxs && DiffOptions.show-line-numbers;
        }
        rightcell := DiffCellView {
            width: sxs ? cellw : 0px;
            avail-width: sxs ? cellw : 0px;
            spans: rowdata.right-spans;
            full-text: rowdata.right-text;
            cols: rowdata.right-cols;
            bg: rowdata.right-bg;
            wrap: DiffOptions.word-wrap;
        }
    }

    // Current find match: an accent outline drawn over the row.
    if root.highlight : Rectangle {
        background: transparent;
        border-width: 2px;
        border-color: Backend.accent;
    }
}

// ---- a segmented toggle for the view mode ----------------------------------

component SegToggle inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> active;
    callback clicked();
    width: 116px;
    background: active ? Backend.accent : transparent;
    HorizontalLayout {
        alignment: center;
        spacing: 6px;
        Icon {
            size: 14px;
            source: root.icon;
            colorize: active ? Backend.on-accent : Backend.fg;
        }
        Text {
            text: label;
            color: active ? Backend.on-accent : Backend.fg;
            font-size: 12px;
            vertical-alignment: center;
        }
    }
    TouchArea { clicked => { root.clicked(); } }
}

component Divider inherits Rectangle {
    width: 1px;
    background: Backend.divider;
}

// A fully theme-driven dropdown (the std-widgets ComboBox draws a fixed white
// border that ignores our palette). Supports both index- and value-bound use.
component ThemedCombo inherits Rectangle {
    in property <[string]> model;
    in-out property <int> current-index: 0;
    in-out property <string> current-value;
    callback selected(string);
    property <string> display: root.current-value != ""
        ? root.current-value
        : (root.model.length > 0 ? root.model[root.current-index] : "");
    height: 28px;
    border-radius: 5px;
    border-width: 1px;
    border-color: Backend.divider;
    background: Backend.bg;
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        Text {
            text: root.display;
            color: Backend.fg;
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        Text { text: "▾"; color: Backend.gutter-fg; vertical-alignment: center; }
    }
    TouchArea { clicked => { popup.show(); } }
    popup := PopupWindow {
        x: 0;
        y: root.height + 2px;
        width: root.width;
        Rectangle {
            background: Backend.panel-bg;
            border-width: 1px;
            border-color: Backend.divider;
            border-radius: 5px;
            VerticalLayout {
                padding: 2px;
                for item[i] in root.model : Rectangle {
                    height: 26px;
                    background: itouch.has-hover ? Backend.hover : transparent;
                    border-radius: 3px;
                    itouch := TouchArea {
                        clicked => {
                            root.current-index = i;
                            root.current-value = item;
                            root.selected(item);
                        }
                    }
                    Text {
                        x: 8px;
                        text: item;
                        color: Backend.fg;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

// ---- the option bar --------------------------------------------------------

component OptionBar inherits Rectangle {
    height: 42px;
    background: Backend.panel-bg;
    Rectangle { y: parent.height - 1px; height: 1px; background: Backend.divider; }

    HorizontalLayout {
        padding: 6px;
        spacing: 10px;
        alignment: start;

        Rectangle {
            border-radius: 5px;
            border-width: 1px;
            border-color: Backend.divider;
            clip: true;
            HorizontalLayout {
                spacing: 0px;
                SegToggle {
                    label: "Side by side";
                    icon: @image-url("icons/columns-2.svg");
                    active: DiffOptions.side-by-side;
                    clicked => { DiffOptions.side-by-side = true; DiffOptions.relayout(); }
                }
                Divider {}
                SegToggle {
                    label: "Unified";
                    icon: @image-url("icons/rows-2.svg");
                    active: !DiffOptions.side-by-side;
                    clicked => { DiffOptions.side-by-side = false; DiffOptions.relayout(); }
                }
            }
        }

        CheckBox {
            text: "Wrap";
            checked: DiffOptions.word-wrap;
            toggled => { DiffOptions.word-wrap = self.checked; DiffOptions.relayout(); }
        }
        CheckBox {
            text: "Line #";
            checked: DiffOptions.show-line-numbers;
            toggled => { DiffOptions.show-line-numbers = self.checked; DiffOptions.relayout(); }
        }

        Divider {}

        CheckBox {
            text: "Ignore WS";
            checked: DiffOptions.ignore-whitespace;
            toggled => { DiffOptions.ignore-whitespace = self.checked; DiffOptions.rediff(); }
        }
        CheckBox {
            text: "Tokens";
            checked: DiffOptions.token-granularity;
            toggled => { DiffOptions.token-granularity = self.checked; DiffOptions.rediff(); }
        }
        CheckBox {
            text: "Syntax";
            checked: DiffOptions.syntax-highlight;
            toggled => { DiffOptions.syntax-highlight = self.checked; DiffOptions.rediff(); }
        }

        Divider {}

        Text { text: "Context"; color: Backend.fg; vertical-alignment: center; }
        Button {
            text: "-";
            clicked => {
                if (DiffOptions.context-lines > 0) {
                    DiffOptions.context-lines -= 1;
                    DiffOptions.rediff();
                }
            }
        }
        Text {
            text: DiffOptions.context-lines;
            color: Backend.fg;
            vertical-alignment: center;
            width: 16px;
            horizontal-alignment: center;
        }
        Button {
            text: "+";
            clicked => { DiffOptions.context-lines += 1; DiffOptions.rediff(); }
        }

        ThemedCombo {
            width: 150px;
            model: ["Patience", "Myers-greedy", "Myers-linear"];
            current-index: DiffOptions.algorithm;
            selected(v) => { DiffOptions.algorithm = self.current-index; DiffOptions.rediff(); }
        }
    }
}

// ---- the repository sidebar ------------------------------------------------

component SectionLabel inherits Text {
    color: Backend.gutter-fg;
    font-size: 11px;
}

component RepoBrowser inherits Rectangle {
    width: Backend.sidebar-width;
    background: Backend.panel-bg;
    // Height of the RECENT COMMITS panel; persisted via Backend.commits-panel-height
    // and adjusted by the drag handle below.
    property <length> commits-height <=> Backend.commits-panel-height;
    Rectangle { x: parent.width - 1px; width: 1px; background: Backend.divider; }

    VerticalLayout {
        padding: 10px;
        spacing: 8px;

        HorizontalLayout {
            SectionLabel { text: "REPOSITORY"; vertical-alignment: center; }
            Rectangle { horizontal-stretch: 1; }
            // Open the settings panel.
            gear := Rectangle {
                width: 16px;
                height: 16px;
                gear-ta := TouchArea { clicked => { Backend.show-settings = true; } }
                Image {
                    width: 14px;
                    height: 14px;
                    image-fit: contain;
                    source: @image-url("icons/settings.svg");
                    colorize: gear-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                }
            }
        }
        ThemedCombo {
            model: Backend.repo-names;
            selected(v) => { Backend.select-repo-index(self.current-index); }
        }
        HorizontalLayout {
            spacing: 4px;
            path-input := LineEdit {
                placeholder-text: "/path/to/repo";
                horizontal-stretch: 1;
                accepted => { Backend.open-repo(self.text); }
            }
            Button { text: "Open"; clicked => { Backend.open-repo(path-input.text); } }
        }
        Button {
            text: "Browse…";
            icon: @image-url("icons/folder-open.svg");
            colorize-icon: true;
            clicked => { Backend.browse-repo(); }
        }
        if Backend.branch != "" : HorizontalLayout {
            spacing: 6px;
            Icon {
                size: 14px;
                source: @image-url("icons/git-branch.svg");
                colorize: Backend.accent;
            }
            // Branch list + checkout (switches on selection).
            ThemedCombo {
                horizontal-stretch: 1;
                model: Backend.branch-names;
                current-value: Backend.branch;
                selected(v) => { Backend.checkout-branch(v); }
            }
        }

        // CHANGES header with a live count and a loading spinner.
        HorizontalLayout {
            spacing: 6px;
            SectionLabel {
                text: "CHANGES (\{Backend.files.length})";
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            // Toggle folder grouping vs staged/unstaged sections.
            group-btn := Rectangle {
                width: 16px;
                height: 16px;
                group-ta := TouchArea {
                    clicked => {
                        Backend.group-by-folder = !Backend.group-by-folder;
                        Backend.regroup-files();
                    }
                }
                Image {
                    width: 13px;
                    height: 13px;
                    image-fit: contain;
                    source: @image-url("icons/folder-open.svg");
                    colorize: Backend.group-by-folder
                        ? Backend.accent
                        : (group-ta.has-hover ? Backend.accent : Backend.gutter-fg);
                }
            }
            // Re-scan the working tree without reopening the repo (also Cmd/Ctrl-R).
            refresh-btn := Rectangle {
                width: 16px;
                height: 16px;
                refresh-ta := TouchArea { clicked => { Backend.refresh(); } }
                Image {
                    width: 13px;
                    height: 13px;
                    image-fit: contain;
                    source: @image-url("icons/refresh-cw.svg");
                    colorize: refresh-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                }
            }
            if Backend.loading : Rectangle {
                width: 13px;
                property <angle> ang: 0deg;
                Timer {
                    interval: 16ms;
                    running: true;
                    triggered => { parent.ang = parent.ang + 9deg; }
                }
                Image {
                    width: 13px;
                    height: 13px;
                    image-fit: contain;
                    source: @image-url("icons/loader-circle.svg");
                    colorize: Backend.gutter-fg;
                    rotation-angle: parent.ang;
                    rotation-origin-x: 6.5px;
                    rotation-origin-y: 6.5px;
                }
            }
        }

        // Filter the changes list by substring.
        HorizontalLayout {
            spacing: 4px;
            Icon {
                size: 13px;
                source: @image-url("icons/search.svg");
                colorize: Backend.gutter-fg;
            }
            filter-input := LineEdit {
                placeholder-text: "Filter files";
                horizontal-stretch: 1;
                edited => { Backend.filter-files(self.text); }
            }
        }

        // Files and commits share the remaining space, split by a draggable
        // divider. The drag is captured by a TouchArea that FILLS this (fixed)
        // area, so the pointer is always measured against a stable origin.
        // Dragging the handle directly would jitter, because the handle moves
        // with the layout and its position lags the pointer by a frame.
        lists-area := Rectangle {
            vertical-stretch: 1;
            property <length> handle-h: 10px;
            // Files pane height; the commits pane takes the rest (>= 80px each).
            property <length> files-h: clamp(self.height - root.commits-height - self.handle-h,
                                             80px, self.height - 80px);

            // Lowest z, fills the area. Only presses that fall through the
            // divider gap reach it (the lists above consume their own), and
            // mouse-y here is relative to this non-moving rectangle.
            resize-ta := TouchArea {
                mouse-cursor: row-resize;
                property <bool> dragging;
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down) {
                        self.dragging = self.mouse-y >= lists-area.files-h - 6px
                                     && self.mouse-y <= lists-area.files-h + lists-area.handle-h + 6px;
                    }
                    if (e.kind == PointerEventKind.up) {
                        self.dragging = false;
                    }
                }
                moved => {
                    if (self.dragging) {
                        root.commits-height = clamp(
                            lists-area.height - self.mouse-y - lists-area.handle-h / 2,
                            80px, lists-area.height - 80px);
                    }
                }
            }

            files-list := ListView {
                y: 0;
                height: lists-area.files-h;
                width: 100%;
                // Scroll the keyboard-selected row into view when it changes.
                property <int> sel: Backend.file-sel-index;
                changed sel => {
                    if (self.sel >= 0) {
                        if (self.sel * 24px < -self.viewport-y) {
                            self.viewport-y = -self.sel * 24px;
                        } else if ((self.sel + 1) * 24px > -self.viewport-y + self.height) {
                            self.viewport-y = -((self.sel + 1) * 24px - self.height);
                        }
                    }
                }
                for f[fidx] in Backend.files : Rectangle {
                    height: 24px;
                    property <bool> selected: !f.is-section && f.path == Backend.current-file;
                    background: selected
                        ? Backend.selection
                        : (!f.is-section && touch.has-hover ? Backend.hover : transparent);
                    touch := TouchArea {
                        clicked => {
                            if (!f.is-section) {
                                Backend.file-sel-index = fidx;
                                Backend.select-file(f.path);
                            }
                        }
                    }

                    // Section / group header (staged-unstaged or folder).
                    if f.is-section : Text {
                        x: 6px;
                        text: f.name;
                        color: Backend.gutter-fg;
                        font-size: 11px;
                        vertical-alignment: center;
                    }

                    // A changed-file row.
                    if !f.is-section : HorizontalLayout {
                        padding-left: 6px + f.depth * 12px;
                        padding-right: 6px;
                        spacing: 6px;
                        StatusIcon { status: f.status; }
                        // Filename first so it stays visible; the directory is
                        // dimmed and elides as the row narrows.
                        Text {
                            text: f.name;
                            color: selected ? white : Backend.fg;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: f.dir;
                            color: Backend.gutter-fg;
                            overflow: elide;
                            horizontal-stretch: 1;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                        if f.staged : Rectangle {
                            width: 8px;
                            Rectangle {
                                width: 6px;
                                height: 6px;
                                border-radius: 3px;
                                background: #73c991;
                            }
                        }
                        // Per-file actions: stage/unstage toggle + discard.
                        Rectangle {
                            width: 16px;
                            stage-ta := TouchArea {
                                clicked => {
                                    if (f.staged) { Backend.unstage-file(f.path); }
                                    else { Backend.stage-file(f.path); }
                                }
                            }
                            Image {
                                width: 13px;
                                height: 13px;
                                source: f.staged
                                    ? @image-url("icons/circle-minus.svg")
                                    : @image-url("icons/circle-plus.svg");
                                colorize: stage-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                            }
                        }
                        Rectangle {
                            width: 16px;
                            discard-ta := TouchArea {
                                clicked => { Backend.confirm-discard = f.path; }
                            }
                            Image {
                                width: 13px;
                                height: 13px;
                                source: @image-url("icons/undo.svg");
                                colorize: discard-ta.has-hover ? #f48771 : Backend.gutter-fg;
                            }
                        }
                    }
                }
            }

            // The divider itself is visual only (no TouchArea) so presses land
            // on resize-ta beneath it.
            Rectangle {
                y: lists-area.files-h;
                width: 100%;
                height: lists-area.handle-h;
                Rectangle {
                    width: 28px;
                    height: 2px;
                    border-radius: 1px;
                    background: resize-ta.dragging || resize-ta.has-hover ? Backend.gutter-fg : Backend.divider;
                }
            }

            VerticalLayout {
                y: lists-area.files-h + lists-area.handle-h;
                width: 100%;
                height: lists-area.height - lists-area.files-h - lists-area.handle-h;
                SectionLabel { text: "RECENT COMMITS"; }
                commits-list := ListView {
                    vertical-stretch: 1;
                    // Scroll the keyboard-selected commit into view when it changes.
                    property <int> sel: Backend.commit-sel-index;
                    changed sel => {
                        if (self.sel >= 0) {
                            if (self.sel * 38px < -self.viewport-y) {
                                self.viewport-y = -self.sel * 38px;
                            } else if ((self.sel + 1) * 38px > -self.viewport-y + self.height) {
                                self.viewport-y = -((self.sel + 1) * 38px - self.height);
                            }
                        }
                    }
                    for c[cidx] in Backend.commits : Rectangle {
                        height: 38px;
                        background: cidx == Backend.commit-sel-index
                                    ? Backend.selection
                                    : (ctouch.has-hover ? Backend.hover : transparent);
                        ctouch := TouchArea {
                            clicked => {
                                Backend.commit-sel-index = cidx;
                                Backend.select-commit(c.oid);
                            }
                        }
                        HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 6px;
                            spacing: 6px;
                            Icon {
                                size: 14px;
                                source: @image-url("icons/git-commit.svg");
                                colorize: Backend.gutter-fg;
                            }
                            VerticalLayout {
                                padding-top: 4px;
                                padding-bottom: 4px;
                                Text {
                                    text: c.summary;
                                    color: Backend.fg;
                                    overflow: elide;
                                    font-size: 12px;
                                }
                                Text {
                                    text: c.short-oid;
                                    color: Backend.gutter-fg;
                                    font-family: Backend.mono-font;
                                    font-size: 10px;
                                }
                            }
                        }
                    }
                }

                // Lazy paging footer: load the next page or the whole history.
                if Backend.more-commits || Backend.loading-commits : HorizontalLayout {
                    spacing: 6px;
                    Button {
                        text: Backend.loading-commits ? "Loading…" : "Load more";
                        enabled: !Backend.loading-commits;
                        clicked => { Backend.load-more-commits(); }
                    }
                    Button {
                        text: "Load all";
                        enabled: !Backend.loading-commits;
                        clicked => { Backend.load-all-commits(); }
                    }
                }
            }
        }

        // Commit bar: message + amend, enabled only when something is staged.
        VerticalLayout {
            spacing: 6px;
            commit-msg := LineEdit {
                placeholder-text: "Commit message";
                enabled: Backend.staged-count > 0;
            }
            HorizontalLayout {
                spacing: 6px;
                amend-cb := CheckBox { text: "Amend"; }
                Rectangle { horizontal-stretch: 1; }
                Button {
                    text: "Commit (\{Backend.staged-count})";
                    enabled: Backend.staged-count > 0 && commit-msg.text != "";
                    clicked => {
                        Backend.commit(commit-msg.text, amend-cb.checked);
                        commit-msg.text = "";
                    }
                }
            }
        }
    }
}

// ---- settings panel --------------------------------------------------------

component SettingsPanel inherits Rectangle {
    // Dim backdrop over the whole window; a click outside the card closes it.
    background: #00000099;
    visible: Backend.show-settings;
    backdrop-ta := TouchArea { clicked => { Backend.show-settings = false; } }

    // Centered card.
    Rectangle {
        width: 440px;
        height: card.preferred-height;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Backend.panel-bg;
        border-radius: 10px;
        border-width: 1px;
        border-color: Backend.divider;
        // Swallow clicks so they don't fall through to the backdrop.
        TouchArea {}

        card := VerticalLayout {
            padding: 22px;
            spacing: 16px;

            Text { text: "Settings"; color: Backend.fg; font-size: 17px; font-weight: 600; }

            // Diff font: curated dropdown + free-text for any installed family.
            VerticalLayout {
                spacing: 6px;
                Text { text: "DIFF FONT"; color: Backend.gutter-fg; font-size: 11px; }
                ThemedCombo {
                    model: Backend.font-choices;
                    current-value: Backend.mono-font;
                    selected(v) => { Backend.mono-font = v; }
                }
                LineEdit {
                    placeholder-text: "or type any installed family…";
                    text: Backend.mono-font;
                    edited => { Backend.mono-font = self.text; }
                }
            }

            // Font size + tab width steppers.
            HorizontalLayout {
                spacing: 24px;
                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "Size"; color: Backend.fg; vertical-alignment: center; }
                    Button { text: "-"; clicked => { Backend.font-size = max(8, Backend.font-size - 1); } }
                    Text {
                        text: "\{Backend.font-size}";
                        color: Backend.fg;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        width: 24px;
                    }
                    Button { text: "+"; clicked => { Backend.font-size = min(32, Backend.font-size + 1); } }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "Tab"; color: Backend.fg; vertical-alignment: center; }
                    Button {
                        text: "-";
                        clicked => {
                            Backend.tab-width = max(1, Backend.tab-width - 1);
                            Backend.set-tab-width(Backend.tab-width);
                        }
                    }
                    Text {
                        text: "\{Backend.tab-width}";
                        color: Backend.fg;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        width: 24px;
                    }
                    Button {
                        text: "+";
                        clicked => {
                            Backend.tab-width = min(16, Backend.tab-width + 1);
                            Backend.set-tab-width(Backend.tab-width);
                        }
                    }
                }
            }

            // Default view.
            VerticalLayout {
                spacing: 6px;
                Text { text: "VIEW"; color: Backend.gutter-fg; font-size: 11px; }
                ThemedCombo {
                    model: ["side-by-side", "unified"];
                    current-value: DiffOptions.side-by-side ? "side-by-side" : "unified";
                    selected(v) => {
                        DiffOptions.side-by-side = (v == "side-by-side");
                        DiffOptions.relayout();
                    }
                }
            }

            // Theme (applied live).
            VerticalLayout {
                spacing: 6px;
                Text { text: "THEME"; color: Backend.gutter-fg; font-size: 11px; }
                ThemedCombo {
                    model: Backend.theme-names;
                    current-value: Backend.theme-name;
                    selected(v) => { Backend.theme-name = v; Backend.set-theme(v); }
                }
            }

            HorizontalLayout {
                alignment: end;
                Button { text: "Done"; clicked => { Backend.show-settings = false; } }
            }
        }
    }
}

// ---- the window ------------------------------------------------------------

export component AppWindow inherits Window {
    title: "diffy";
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 800px;
    min-height: 480px;
    background: Backend.bg;

    forward-focus: key-scope;
    key-scope := FocusScope {
        // Global keyboard navigation. LineEdits grab focus and consume their own
        // keys, so these only fire when no text field is focused.
        key-pressed(event) => {
            if (event.text == Key.Escape && Backend.show-settings) {
                Backend.show-settings = false;
                return accept;
            }
            if (event.text == Key.Escape && Backend.show-find) {
                Backend.show-find = false;
                Backend.find-close();
                return accept;
            }
            if ((event.modifiers.control || event.modifiers.meta) && event.text == "f") {
                Backend.show-find = true;
                return accept;
            }
            if (event.text == Key.UpArrow || event.text == "k") {
                Backend.navigate("up");
                return accept;
            }
            if (event.text == Key.DownArrow || event.text == "j") {
                Backend.navigate("down");
                return accept;
            }
            if (event.text == Key.Tab) {
                Backend.navigate("tab");
                return accept;
            }
            if (event.text == "n") {
                Backend.navigate("next-hunk");
                return accept;
            }
            if (event.text == "p") {
                Backend.navigate("prev-hunk");
                return accept;
            }
            if (event.text == Key.Return) {
                Backend.navigate("activate");
                return accept;
            }
            if ((event.modifiers.control || event.modifiers.meta) && event.text == "r") {
                Backend.refresh();
                return accept;
            }
            return reject;
        }

      content := Rectangle {
        HorizontalLayout {
        spacing: 0px;
        RepoBrowser {}

        // Draggable resize gutter between the sidebar and the diff. The handle's
        // TouchArea is local (so the cursor/hover highlight are correct), but it
        // derives the new width from the pointer's absolute position, so it can't
        // drift or feed back on itself as the layout reflows.
        Rectangle {
            width: 6px;
            background: Backend.panel-bg;
            sidebar-handle := TouchArea {
                mouse-cursor: col-resize;
                moved => {
                    if (self.pressed) {
                        Backend.sidebar-width = clamp(
                            self.absolute-position.x - content.absolute-position.x
                                + self.mouse-x - 3px,
                            180px, content.width - 360px);
                    }
                }
            }
            Rectangle {
                x: 2px;
                width: 2px;
                background: sidebar-handle.pressed || sidebar-handle.has-hover
                            ? Backend.gutter-fg : transparent;
            }
        }

        VerticalLayout {
            spacing: 0px;
            horizontal-stretch: 1;

            // header strip
            Rectangle {
                height: 30px;
                background: Backend.bg;
                Rectangle { y: parent.height - 1px; height: 1px; background: Backend.divider; }
                HorizontalLayout {
                    padding-left: 12px;
                    spacing: 8px;
                    Text {
                        text: Backend.current-file == "" ? "No file selected" : Backend.current-file;
                        color: Backend.current-file == "" ? Backend.gutter-fg : Backend.fg;
                        vertical-alignment: center;
                        font-family: Backend.mono-font;
                        font-size: 12px;
                    }
                }
            }

            OptionBar {}

            // The diff itself: a single virtualized ListView of full rows, so
            // only the visible rows are instantiated (large diffs stay fast).
            // Each row draws both sides with a centred divider in side-by-side
            // mode. Long lines clip at the cell edge unless word-wrap is on.
            diff-area := Rectangle {
                background: Backend.bg;
                vertical-stretch: 1;
                clip: true;

                if Backend.rows.length > 0 : ListView {
                    // A ListView is a widget, not a layout, so it must be told
                    // to fill the (plain Rectangle) diff area explicitly.
                    width: 100%;
                    height: 100%;
                    // Jump-to-hunk: scroll so the requested row is near the top.
                    // Approximate (uniform row height) — exact enough to land.
                    property <int> scroll-to: Backend.diff-scroll-row;
                    changed scroll-to => {
                        if (self.scroll-to >= 0) {
                            self.viewport-y = -self.scroll-to * Backend.font-size * 1.6px;
                        }
                    }
                    for data[idx] in Backend.rows : DiffRow {
                        width: parent.width;
                        rowdata: data;
                        highlight: idx == Backend.find-current-row;
                    }
                }

                // empty state
                if Backend.rows.length == 0 : VerticalLayout {
                    alignment: center;
                    spacing: 12px;
                    Rectangle {
                        height: 44px;
                        Image {
                            width: 44px;
                            height: 44px;
                            image-fit: contain;
                            source: @image-url("icons/git-compare.svg");
                            colorize: Backend.gutter-fg;
                        }
                    }
                    Text {
                        text: Backend.diff-note != ""
                            ? Backend.diff-note
                            : (Backend.current-file == ""
                                ? "Select a changed file on the left to view its diff"
                                : "No textual changes to display");
                        color: Backend.gutter-fg;
                        horizontal-alignment: center;
                        font-size: 13px;
                    }
                }

                // Find-in-diff bar (Cmd/Ctrl-F): a top-right overlay on the diff.
                if Backend.show-find : Rectangle {
                    y: 8px;
                    x: parent.width - self.width - 12px;
                    width: 320px;
                    height: 38px;
                    background: Backend.panel-bg;
                    border-width: 1px;
                    border-color: Backend.divider;
                    border-radius: 6px;
                    HorizontalLayout {
                        padding: 6px;
                        spacing: 6px;
                        find-input := LineEdit {
                            placeholder-text: "Find in diff";
                            horizontal-stretch: 1;
                            init => { self.focus(); }
                            edited => { Backend.find(self.text); }
                            accepted => { Backend.find-next(); }
                        }
                        Text {
                            text: "\{Backend.find-current}/\{Backend.find-count}";
                            color: Backend.gutter-fg;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                        Button { text: "<"; clicked => { Backend.find-prev(); } }
                        Button { text: ">"; clicked => { Backend.find-next(); } }
                        Button {
                            text: "x";
                            clicked => {
                                Backend.show-find = false;
                                Backend.find-close();
                            }
                        }
                    }
                }
            }

            // status bar
            Rectangle {
                height: 22px;
                background: Backend.accent;
                Text {
                    x: 8px;
                    text: Backend.status-text;
                    color: white;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }
        }
      }
    }

    // Periodic background refresh of the changes list (Slint has no focus event).
    Timer {
        interval: 5s;
        running: true;
        triggered => { Backend.auto-refresh(); }
    }

    // Settings overlay sits above everything.
    SettingsPanel {}

    // Discard confirmation (destructive — always confirm first).
    if Backend.confirm-discard != "" : Rectangle {
        background: #00000099;
        TouchArea { clicked => { Backend.confirm-discard = ""; } }
        Rectangle {
            width: 380px;
            height: 150px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Backend.panel-bg;
            border-radius: 10px;
            border-width: 1px;
            border-color: Backend.divider;
            TouchArea {}
            VerticalLayout {
                padding: 20px;
                spacing: 12px;
                Text { text: "Discard changes?"; color: Backend.fg; font-size: 16px; font-weight: 600; }
                Text {
                    text: Backend.confirm-discard;
                    color: Backend.gutter-fg;
                    font-size: 12px;
                    overflow: elide;
                }
                Text {
                    text: "This cannot be undone.";
                    color: #f48771;
                    font-size: 11px;
                }
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    Button { text: "Cancel"; clicked => { Backend.confirm-discard = ""; } }
                    Button {
                        text: "Discard";
                        clicked => {
                            Backend.discard-file(Backend.confirm-discard);
                            Backend.confirm-discard = "";
                        }
                    }
                }
            }
        }
    }
}
