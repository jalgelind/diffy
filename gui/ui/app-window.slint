// Button + CheckBox are defined below as theme-aware components (the std-widgets
// ones are locked to the compile-time fluent-dark style and become unreadable on
// light diffy themes — e.g. white text on a white button).
import { ListView, ScrollView, Palette } from "std-widgets.slint";

// ---- shared data structures (mirrored by generated C++ types) --------------

export struct DiffSpan {
    text: string,
    color: color,
    bold: bool,
}

// One rendered row: a single visual line of each cell (its list of coloured
// spans). C++ does the word-wrapping and emits ONE DiffRowData per visual line —
// a logical diff line that wraps into N sub-lines becomes N consecutive rows, so
// every row is exactly one text line tall. That uniform height is what keeps the
// ListView scrollbar exact and jump-to-hunk precise. Continuation rows carry the
// same cell background but blank line numbers (set on the first row only).
export struct DiffRowData {
    is-header: bool,
    header: string,
    old-no: string,
    new-no: string,
    left-spans: [DiffSpan],
    left-bg: color,
    left-present: bool,
    left-len: int,   // character count of the left cell's text (for selection)
    right-spans: [DiffSpan],
    right-bg: color,
    right-present: bool,
    right-len: int,  // character count of the right cell's text
    // Review comment rows are interleaved into the diff beneath their anchor line.
    // Each comment is a header row (avatar + author + time) followed by wrapped
    // body rows, all uniform-height so the scrollbar/jump math stays exact.
    is-comment: bool,
    comment-is-head: bool,     // true = the avatar/author/time header row
    comment-author: string,    // (head row)
    comment-time: string,      // relative timestamp, e.g. "3d" (head row)
    comment-body: string,      // one wrapped line (body row)
    comment-depth: int,        // reply nesting -> left indent
    comment-initials: string,  // avatar fallback letters (head row)
    comment-tint: color,       // avatar fallback circle colour (head row)
    comment-avatar: image,     // fetched avatar; empty => draw the initials circle
    comment-outdated: bool,
}

export struct FileEntry {
    path: string,
    status: string,
    name: string,   // basename, kept visible when the row is too narrow
    dir: string,    // leading directory (elided first)
    staged: bool,
    is-section: bool,  // a non-selectable section/group header row
    depth: int,        // indent level (folder grouping)
    comment-count: int,  // review comments anchored to this file (PR mode; 0 otherwise)
}

export struct CommitEntry {
    oid: string,
    short-oid: string,
    summary: string,
}

// One open pull request shown in the right sidebar (from a hosted-review
// backend). `state` is a short glyph/word for the approval state.
export struct PrEntry {
    id: string,
    title: string,
    author: string,
    source: string,
    dest: string,
    state: string,
    comments: int,
    updated: string,
    updated-rel: string,  // relative time, e.g. "3d"
    avatar: image,        // author avatar (empty => initials circle)
    initials: string,     // author initials fallback
    tint: color,          // initials-circle colour
    draft: bool,
    is-section: bool,   // a non-clickable group header row (title = section name)
}

// One comment shown in the PR "Comments" shelf.
export struct PrComment {
    author: string,
    snippet: string,
    location: string,   // "path:line" or "general"
    path: string,       // anchored file (empty for general / PR-level comments)
    line: int,          // anchored line on `side` (0 when general)
    side: string,       // "new" | "old" (which gutter `line` refers to)
}

// ---- option-bar state, shared with C++ -------------------------------------

export global DiffOptions {
    in-out property <bool> side-by-side: true;
    in-out property <bool> word-wrap: false;
    in-out property <bool> show-line-numbers: true;
    in-out property <bool> ignore-whitespace: false;
    in-out property <bool> token-granularity: true;
    in-out property <bool> syntax-highlight: true;
    in-out property <int> context-lines: 3;
    in-out property <int> algorithm: 0;  // 0 patience, 1 myers-greedy, 2 myers-linear

    callback relayout();  // layout-only change (cheap)
    callback rediff();    // needs a re-diff
}

// ---- everything C++ drives -------------------------------------------------

export global Backend {
    in property <[string]> repo-names;
    in property <[FileEntry]> files;
    in property <[CommitEntry]> commits;
    in property <bool> more-commits: false;     // history has more than is loaded
    in property <bool> loading-commits: false;  // a load-more is in flight
    in property <[DiffRowData]> rows;

    // Persisted layout, two-way: dragged in the UI, read back on exit to save.
    in-out property <length> sidebar-width: 300px;
    in-out property <length> commits-panel-height: 150px;
    // Keyboard-navigation selection (row index in each list, -1 = none). Driven by
    // C++ for key nav and by clicks; the lists scroll the row into view on change.
    in-out property <int> file-sel-index: -1;
    in-out property <int> commit-sel-index: -1;

    in property <[string]> branch-names;   // local branches for the checkout combo
    in property <int> staged-count: 0;     // staged files (enables Commit)
    in property <int> changes-count: 0;    // total working-tree changes (shown on the WT entry)
    in property <bool> on-working-tree: true;  // false while browsing a historical commit
    in-out property <bool> group-by-folder: false;  // changes-list grouping mode
    in-out property <string> confirm-discard: "";  // path pending a discard confirm
    in property <string> current-file: "";
    in property <string> diff-note: "";  // why the file isn't diffed (binary/large)
    in-out property <float> diff-scroll-y: -1;  // jump the diff to this pixel offset (< 0 = no-op)
    // Find-in-diff state.
    in-out property <bool> show-find: false;
    in property <int> find-count: 0;          // total matches
    in property <int> find-current: 0;        // 1-based index of current match
    in-out property <int> find-current-row: -1;  // model row to highlight
    in property <string> branch: "";
    in property <string> status-text: "Open a repository to begin.";
    // Network activity for the status bar: foreground (interactive) vs background
    // (prefetch) request counts, plus a label of what the foreground is doing.
    in property <int> net-active: 0;
    in property <int> net-prefetch: 0;
    in property <string> net-label;

    // Diff overview header: PR description (Full diff) or commit message (commit
    // view). Shown above the diff when there's content; user-collapsible.
    in property <bool> overview-visible: false;
    in-out property <bool> overview-collapsed: false;
    in property <string> overview-title;
    in property <string> overview-subtitle;
    in property <string> overview-body;
    in property <bool> loading: false;  // a repo open is in progress
    in property <bool> dark: true;      // active theme is dark (drives std-widget chrome)
    in property <int> max-cols: 0;  // longest line in chars, for horizontal scroll

    in-out property <string> mono-font: "Menlo";
    in-out property <int> font-size: 13;
    // Settings panel state + values it edits.
    in-out property <bool> show-settings: false;
    // Bitbucket "Connect" dialog (P1 Connect card). Credentials are verified live
    // (whoami) off the UI thread; with a workspace+repo an open-PR count is also
    // fetched so the connection can be tested end-to-end. The token is stored in
    // the OS credential vault, never in config.
    in-out property <bool> show-bitbucket: false;
    in property <bool> bitbucket-connecting: false;
    in property <bool> bitbucket-connected: false;
    in property <string> bitbucket-status: "";
    callback connect-bitbucket(string, string, string, string);  // workspace, repo, username, app-password
    // Inject text into the focused field via a synthetic (modifier-free) key
    // event — a workaround for the upstream Slint/winit stuck-modifier bug that
    // drops AltGr characters like "@" (Slint #6263). See main.cpp.
    callback type-text(string);

    // Pull requests for the current repo (populated when its origin is a Bitbucket
    // remote and an account is connected). See main.cpp detection.
    in property <bool> has-bitbucket: false;
    in property <bool> loading-prs: false;
    in property <[PrEntry]> pull-requests;
    callback open-pr(string);    // pr id
    callback refresh-prs();
    in property <bool> more-prs: false;  // the PR history has another page
    callback load-more-prs();
    // PR detail mode: the right sidebar shows a back row + PR header + the PR's
    // commits; the left shows the PR's changed files.
    in property <bool> pr-open: false;
    in-out property <bool> pr-list-collapsed: false;  // PR-list shelf; auto-set on open, user-toggle
    in property <string> pr-title;      // "#id  title"
    in property <string> pr-subtitle;   // "src → dst · state"
    in property <string> pr-stat;       // "N files · +x −y"
    in property <string> pr-url;        // web URL of the PR (quick actions)
    in property <[PrComment]> pr-comments;  // all of the open PR's comments (Comments shelf)
    callback close-pr();
    callback open-url(string);          // open a URL in the system browser
    callback show-pr-aggregate();  // leave a single-commit view, show the full PR diff
    in-out property <int> tab-width: 4;
    in property <[string]> font-choices;   // curated monospace families (per-OS)
    in property <[string]> theme-names;     // theme .conf files found on disk
    in-out property <string> theme-name;    // currently applied theme
    in property <color> bg: #1e1e1e;
    in property <color> panel-bg: #252526;
    in property <color> fg: #d4d4d4;
    in property <color> gutter-fg: #6e7681;
    in property <color> accent: #0e639c;
    in property <color> on-accent: white;  // contrasts with accent (set per theme)
    in property <color> header-bg: #2d2d30;
    in property <color> header-fg: #9cdcfe;
    in property <color> divider: #3c3c3c;     // separators / borders
    in property <color> selection: #094771;   // selected list row
    in property <color> hover: #2a2d2e;        // hovered list row

    callback open-repo(string);
    callback browse-repo();
    callback select-repo-index(int);
    callback select-file(string);
    callback select-commit(string);
    callback load-more-commits();
    callback load-all-commits();
    callback filter-files(string);  // substring filter for the changes list
    callback navigate(string);      // keyboard nav: "up"|"down"|"tab"|"activate"
    callback refresh();             // re-scan status + reload commits
    callback set-tab-width(int);    // re-render with a new tab stop
    callback set-theme(string);     // load + apply a theme by name, live
    callback find(string);          // run a find-in-diff query
    callback find-next();
    callback find-prev();
    callback find-close();
    callback stage-file(string);
    callback unstage-file(string);
    callback discard-file(string);  // destructive — confirm in the UI first
    callback commit(string, bool);  // message, amend
    callback select-working-tree();  // return to the uncommitted-changes view
    callback checkout-branch(string);
    callback auto-refresh();        // periodic background status re-scan
    callback regroup-files();       // re-render the changes list after a grouping change
    callback set-base-ref(string);  // diff the working tree against this ref ("" = HEAD)
    // Report the diff cell width and measured monospace advance (both in logical
    // px) so C++ can compute the exact wrap column count and re-wrap the rows.
    callback set-wrap-metrics(float /* cell-px */, float /* advance-px */);

    // Diff text selection (character-level, monospace hit-tested). The selection is
    // an (anchor -> focus) span over {row, column} pairs on ONE side of the diff.
    // Rows are visual row indices; columns are 0-based character offsets. row == -1
    // means no selection. Consumers normalize (row-major, then column).
    in-out property <int> sel-anchor-row: -1;
    in-out property <int> sel-anchor-col: 0;
    in-out property <int> sel-focus-row: -1;
    in-out property <int> sel-focus-col: 0;
    in-out property <int> sel-side: 1;         // 0 = left/old cell, 1 = right/new cell
    // Measured monospace glyph advance (logical px per column); drives x<->column
    // hit-testing and the selection highlight. Kept >0 to avoid divide-by-zero.
    in-out property <length> char-advance: 8px;
    callback copy-selection();      // copy the selected text span to the clipboard
    // Jump from a sidebar comment reference to the anchored code: open the file
    // (if needed) and scroll/select the anchored line. path == "" is a no-op
    // (general / PR-level comment).
    callback open-comment(string /* path */, int /* line */, string /* side */);

    // Comment composer. open-composer asks C++ to resolve the anchor (from the
    // current selection, or the whole PR when general) and populate the fields
    // below before showing the overlay. submit-comment posts the body.
    in-out property <bool> composer-open: false;
    in-out property <bool> composer-general: false;  // true = whole-PR comment
    in-out property <string> composer-target: "";    // human label of the anchor
    in-out property <bool> posting-comment: false;    // in-flight feedback
    callback open-composer(bool /* general */);
    callback submit-comment(string /* body */);

    // Context-menu actions.
    callback copy-to-clipboard(string);
    callback open-file(string);     // repo-relative path
    callback reveal-file(string);   // repo-relative path
    callback checkout-commit(string);          // oid (detached)
    callback create-branch(string, string);    // (oid, branch-name)
    in-out property <string> create-branch-oid: "";  // non-empty -> show name prompt
}

// ---- icons -----------------------------------------------------------------

// A monochrome (Lucide) icon, tinted to the theme. Override `colorize`/`size`
// at the call site; set `source` with @image-url("icons/<name>.svg").
// The icon is a fixed-width wrapper that stretches to its layout cell's height
// and centers the glyph inside it, so it sits vertically centered next to text.
component Icon inherits Rectangle {
    in property <length> size: 16px;
    in property <image> source;
    in property <color> colorize: Backend.fg;
    in property <angle> rotation: 0deg;
    width: size;
    Image {
        width: root.size;
        height: root.size;
        image-fit: contain;
        source: root.source;
        colorize: root.colorize;
        rotation-angle: root.rotation;
    }
}

// File-status badge: picks a Lucide circle glyph + colour from the status code.
component StatusIcon inherits Rectangle {
    in property <string> status;
    width: 15px;
    Image {
        width: 15px;
        height: 15px;
        image-fit: contain;
        source: status == "D" ? @image-url("icons/circle-minus.svg")
              : status == "M" ? @image-url("icons/circle-dot.svg")
              : status == "?" ? @image-url("icons/circle-help.svg")
              : (status == "A" || status == "R" || status == "C") ? @image-url("icons/circle-plus.svg")
              : @image-url("icons/circle-dot.svg");
        colorize: status == "D" ? #f48771
                : status == "M" ? #e2c08d
                : status == "?" ? #73c991
                : status == "A" ? #73c991
                : Backend.accent;
    }
}

// ---- theme-aware Button / CheckBox (replace the fixed-style std-widgets) -----

component Button inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <image> icon;
    in property <bool> colorize-icon: false;
    callback clicked();
    height: 28px;
    min-width: 30px;
    border-radius: 5px;
    border-width: root.primary ? 0px : 1px;
    border-color: Backend.divider;
    background: !root.enabled ? Backend.bg
              : root.primary ? Backend.accent
              : (btn-ta.has-hover ? Backend.hover : Backend.bg);
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        alignment: center;
        if root.colorize-icon : Image {
            width: 14px;
            height: 14px;
            image-fit: contain;
            source: root.icon;
            colorize: root.primary ? Backend.on-accent : Backend.fg;
        }
        Text {
            text: root.text;
            color: !root.enabled ? Backend.gutter-fg
                 : (root.primary ? Backend.on-accent : Backend.fg);
            font-size: 12px;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
    // Full-button hit area, on top of the content so the whole button is clickable.
    btn-ta := TouchArea {
        width: 100%;
        height: 100%;
        enabled <=> root.enabled;
        clicked => { root.clicked(); }
    }
}

component CheckBox inherits Rectangle {
    in property <string> text;
    in-out property <bool> checked;
    callback toggled(bool);
    height: 24px;
    cb-ta := TouchArea {
        clicked => { root.checked = !root.checked; root.toggled(root.checked); }
    }
    HorizontalLayout {
        spacing: 6px;
        alignment: start;
        Rectangle {
            width: 16px;
            height: 16px;
            y: (parent.height - self.height) / 2;
            border-radius: 3px;
            border-width: 1px;
            border-color: root.checked ? Backend.accent : Backend.divider;
            background: root.checked ? Backend.accent : transparent;
            if root.checked : Text {
                text: "✓";
                color: Backend.on-accent;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
        Text {
            text: root.text;
            color: Backend.fg;
            font-size: 12px;
            vertical-alignment: center;
        }
    }
}

// Theme-aware single-line text field (the std-widgets LineEdit is locked to the
// fixed style and renders light-on-light on light themes).
component LineEdit inherits Rectangle {
    in property <string> placeholder-text;
    in-out property <string> text <=> ti.text;
    in property <bool> enabled <=> ti.enabled;
    in property <bool> password: false;  // mask input (App passwords / tokens)
    out property <bool> has-focus <=> ti.has-focus;
    callback edited(string);
    callback accepted();
    // Makes the component focusable and forwards self.focus() to the TextInput.
    forward-focus: ti;
    height: 28px;
    min-width: 40px;
    border-radius: 5px;
    border-width: 1px;
    border-color: ti.has-focus ? Backend.accent : Backend.divider;
    background: Backend.bg;
    Text {
        x: 8px;
        width: parent.width - 16px;
        height: 100%;
        visible: ti.text == "";
        text: root.placeholder-text;
        color: Backend.gutter-fg;
        font-size: 13px;
        vertical-alignment: center;
        overflow: elide;
    }
    ti := TextInput {
        x: 8px;
        width: parent.width - 16px;
        height: 100%;
        color: Backend.fg;
        font-size: 13px;
        single-line: true;
        input-type: root.password ? InputType.password : InputType.text;
        vertical-alignment: center;
        edited => { root.edited(self.text); }
        accepted => { root.accepted(); }
    }
}

// Theme-aware multi-line text field (a word-wrapping TextInput inside a bordered
// box that scrolls once the text outgrows it). Used for the commit body.
component TextArea inherits Rectangle {
    in property <string> placeholder-text;
    in-out property <string> text <=> ti.text;
    out property <bool> has-focus <=> ti.has-focus;
    forward-focus: ti;
    min-width: 40px;
    border-radius: 5px;
    border-width: 1px;
    border-color: ti.has-focus ? Backend.accent : Backend.divider;
    background: Backend.bg;
    clip: true;
    Text {
        x: 8px;
        y: 6px;
        width: parent.width - 16px;
        visible: ti.text == "";
        text: root.placeholder-text;
        color: Backend.gutter-fg;
        font-size: 13px;
        wrap: word-wrap;
    }
    // A Flickable lets the caret follow long bodies past the visible height.
    Flickable {
        x: 8px;
        y: 6px;
        width: parent.width - 16px;
        height: parent.height - 12px;
        viewport-height: max(self.height, ti.preferred-height);
        ti := TextInput {
            width: parent.width;
            color: Backend.fg;
            font-size: 13px;
            single-line: false;
            wrap: word-wrap;
        }
    }
}

// ---- one diff line ---------------------------------------------------------

component DiffCellView inherits Rectangle {
    in property <[DiffSpan]> spans;
    in property <color> bg;
    in property <int> row-index: -1;   // visual row index (for selection)
    in property <int> side: 1;         // 0 = left/old, 1 = right/new
    in property <int> text-len: 0;     // character count of this cell's text
    // Callback so the row can hit-test: report a press/drag at char column `col`
    // on this side/row. `extend` means "shift-click / drag" (move focus only).
    callback select-at(int /* col */, int /* row */, bool /* extend */);

    property <length> pad: 6px;
    property <length> adv: max(1px, Backend.char-advance);

    // Is this cell within the current selection, and on the selected side?
    property <bool> anchor-first:
        Backend.sel-anchor-row < Backend.sel-focus-row
        || (Backend.sel-anchor-row == Backend.sel-focus-row
            && Backend.sel-anchor-col <= Backend.sel-focus-col);
    property <int> s-row: anchor-first ? Backend.sel-anchor-row : Backend.sel-focus-row;
    property <int> s-col: anchor-first ? Backend.sel-anchor-col : Backend.sel-focus-col;
    property <int> e-row: anchor-first ? Backend.sel-focus-row : Backend.sel-anchor-row;
    property <int> e-col: anchor-first ? Backend.sel-focus-col : Backend.sel-anchor-col;
    property <bool> in-range: Backend.sel-anchor-row >= 0 && root.side == Backend.sel-side
        && root.row-index >= s-row && root.row-index <= e-row;
    // Column bounds for THIS row, clamped to its own text length.
    property <int> c0: clamp(root.row-index == s-row ? s-col : 0, 0, root.text-len);
    property <int> c1: clamp(root.row-index == e-row ? e-col : root.text-len, 0, root.text-len);

    background: bg;
    clip: true;  // long lines clip at the cell edge; wrap/unified reveals them

    // Selection highlight (under the text). Full-width tail on interior rows so a
    // multi-line selection reads as a continuous block.
    if in-range && (root.c1 > root.c0 || root.row-index < e-row) : Rectangle {
        x: root.pad + root.c0 * root.adv;
        width: (root.row-index < e-row ? root.text-len - root.c0 : root.c1 - root.c0) * root.adv
               + (root.row-index < e-row ? root.adv : 0px);  // +1 col hints the newline
        background: Backend.selection;
    }

    // One visual line: a row of coloured spans. Wrapping already happened in C++
    // (this cell is a single wrapped sub-line), so every span keeps its per-token
    // syntax/diff colour.
    HorizontalLayout {
        alignment: start;
        // No inter-span gap: spans must butt together so the rendered text width
        // is exact. (The style's default layout-spacing would insert a gap between
        // every span, and re-tokenising on WS-toggle changes the span count —
        // making the spacing between words visibly shift.)
        spacing: 0px;
        padding-left: root.pad;
        for span in spans : Text {
            text: span.text;
            color: span.color;
            font-family: Backend.mono-font;
            font-size: Backend.font-size * 1px;
            font-weight: span.bold ? 700 : 400;
            vertical-alignment: center;
        }
    }

    // Transparent hit layer: press sets the anchor, drag (capture gives us
    // out-of-bounds coords) extends across rows/columns; Shift+click extends.
    sel-ta := TouchArea {
        mouse-cursor: text;
        property <length> row-h: Backend.font-size * 1.6px;
        function col-at(mx: length) -> int {
            return max(0, round((mx - root.pad) / root.adv));
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                root.select-at(self.col-at(self.mouse-x), root.row-index, e.modifiers.shift);
            }
        }
        moved => {
            if (self.pressed) {
                // Capture keeps events here even past the cell edge: derive the row
                // the pointer is over from the vertical offset.
                root.select-at(self.col-at(self.mouse-x),
                               root.row-index + floor(self.mouse-y / self.row-h), true);
            }
        }
    }
}

component LineNo inherits Rectangle {
    in property <string> text;
    width: 48px;
    // Right-align the number but keep a right margin so it doesn't touch the diff.
    Text {
        x: 0;
        width: max(0px, parent.width - 10px);
        height: parent.height;
        text: root.text;
        color: Backend.gutter-fg;
        font-family: Backend.mono-font;
        font-size: Backend.font-size * 1px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
}

// One full diff row used as a (virtualized) ListView delegate. Side-by-side
// shows both cells with a centred 1px divider; unified shows one cell with both
// line-number gutters. Both cells live in the same HorizontalLayout, so they
// share a height automatically — wrapped lines stay aligned across the divider.
component DiffRow inherits Rectangle {
    in property <DiffRowData> rowdata;
    in property <bool> highlight: false;  // current find match
    in property <int> index: -1;          // visual row index (for selection)
    // Begin/extend a character-level selection on `sd` (0=left/old, 1=right/new).
    // extend (Shift+click or drag) moves only the focus end; a plain press starts
    // fresh and pins the side. Ignored on header / comment rows.
    function select(col: int, row: int, sd: int, extend: bool) {
        if (rowdata.is-header || rowdata.is-comment) {
            return;
        }
        if (extend && Backend.sel-anchor-row >= 0) {
            Backend.sel-focus-row = row;
            Backend.sel-focus-col = col;
        } else {
            Backend.sel-side = sd;
            Backend.sel-anchor-row = row;
            Backend.sel-anchor-col = col;
            Backend.sel-focus-row = row;
            Backend.sel-focus-col = col;
        }
    }
    // Explicit per-cell width (one gutter per shown line-number column, minus the
    // 1px divider in side-by-side). Giving cells a definite width is what lets
    // the wrapped Text report a real height-for-width.
    property <length> gut: DiffOptions.show-line-numbers ? 48px : 0px;
    property <bool> sxs: DiffOptions.side-by-side;
    property <length> cellw: max(10px, sxs
        ? (root.width - 2 * gut - 1px) / 2
        : (root.width - 2 * gut));
    // Content rows are exactly one text line tall (C++ pre-split wrapped lines),
    // which keeps the scrollbar/jump math exact. Comment header rows are taller so
    // the avatar has room; comment body lines are a touch roomier than code. The
    // C++ scroll math mirrors these three heights (see row_pixel_offset).
    height: rowdata.is-comment
        ? (rowdata.comment-is-head ? Backend.font-size * 2.8px : Backend.font-size * 1.8px)
        : Backend.font-size * 1.6px;

    if rowdata.is-header : Rectangle {
        height: Backend.font-size * 1.6px;
        background: Backend.header-bg;
        Rectangle { x: 0; width: 3px; background: Backend.accent; }
        Text {
            x: 12px;
            text: rowdata.header;
            color: Backend.header-fg;
            font-family: Backend.mono-font;
            font-size: Backend.font-size * 1px;
            vertical-alignment: center;
        }
    }

    // Review comment row. Each comment is a header row (avatar + author + time)
    // then wrapped body rows; replies indent one level. Uniform height per row is
    // preserved (C++ pre-wraps), so the avatar is one line tall.
    if rowdata.is-comment : Rectangle {
        background: rowdata.comment-outdated ? Backend.panel-bg : Backend.header-bg;
        // Thread accent bar, indented by reply depth.
        Rectangle {
            x: 8px + rowdata.comment-depth * 16px;
            width: 2px;
            background: rowdata.comment-outdated ? Backend.gutter-fg : Backend.accent;
        }
        HorizontalLayout {
            padding-left: 14px + rowdata.comment-depth * 16px;
            padding-right: 8px;
            spacing: 6px;
            // Avatar column (fixed) — rendered only on the header row so body lines
            // align beneath the author. The circle is explicitly centred in the
            // column both ways (a bare child would pin to the top-left).
            Rectangle {
                width: 34px;
                // Real avatar: already center-cropped, downscaled and circle-masked
                // (with an AA edge) in C++, so we just blit it — no clip needed.
                if rowdata.comment-is-head && rowdata.comment-avatar.width > 0 : Image {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    width: 26px;
                    height: 26px;
                    image-rendering: smooth;
                    source: rowdata.comment-avatar;
                }
                // Fallback: a tinted initials circle.
                if rowdata.comment-is-head && rowdata.comment-avatar.width == 0 : Rectangle {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    width: 26px;
                    height: 26px;
                    border-radius: 13px;
                    background: rowdata.comment-tint;
                    Text {
                        width: 100%;
                        height: 100%;
                        text: rowdata.comment-initials;
                        color: #ffffff;
                        font-size: 12px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
            // Header (author + relative time) or a wrapped body line.
            if rowdata.comment-is-head : HorizontalLayout {
                spacing: 6px;
                Text {
                    text: rowdata.comment-author;
                    color: rowdata.comment-outdated ? Backend.gutter-fg : Backend.fg;
                    font-size: Backend.font-size * 1px;
                    font-weight: 700;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Text {
                    text: rowdata.comment-time;
                    color: Backend.gutter-fg;
                    font-size: (Backend.font-size - 1) * 1px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
            }
            if !rowdata.comment-is-head : Text {
                text: rowdata.comment-body;
                color: Backend.fg;
                font-size: Backend.font-size * 1px;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }

    // All cells/gutters are always present (widths collapse to 0 when unused) so
    // their heights stay referenceable from the row height binding above.
    body := HorizontalLayout {
        visible: !rowdata.is-header && !rowdata.is-comment;
        spacing: 0px;
        // Side-by-side: old# on the left (new# is the right gutter below). Unified:
        // a single gutter showing the new line number, or the old one for deletions.
        LineNo {
            text: sxs ? rowdata.old-no : (rowdata.new-no != "" ? rowdata.new-no : rowdata.old-no);
            width: DiffOptions.show-line-numbers ? 48px : 0px;
            visible: DiffOptions.show-line-numbers;
        }
        leftcell := DiffCellView {
            width: cellw;
            spans: rowdata.left-spans;
            bg: rowdata.left-bg;
            row-index: root.index;
            side: 0;
            text-len: rowdata.left-len;
            select-at(col, row, extend) => { root.select(col, row, 0, extend); }
        }
        Rectangle { width: sxs ? 1px : 0px; background: Backend.divider; }
        LineNo {
            text: rowdata.new-no;
            width: (sxs && DiffOptions.show-line-numbers) ? 48px : 0px;
            visible: sxs && DiffOptions.show-line-numbers;
        }
        rightcell := DiffCellView {
            width: sxs ? cellw : 0px;
            spans: rowdata.right-spans;
            bg: rowdata.right-bg;
            row-index: root.index;
            side: 1;
            text-len: rowdata.right-len;
            select-at(col, row, extend) => { root.select(col, row, 1, extend); }
        }
    }

    // Current find match: an accent outline drawn over the row.
    if root.highlight : Rectangle {
        background: transparent;
        border-width: 2px;
        border-color: Backend.accent;
    }
}

// ---- a segmented toggle for the view mode ----------------------------------

component SegToggle inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> active;
    callback clicked();
    width: 52px;
    background: active ? Backend.accent : transparent;
    VerticalLayout {
        alignment: center;
        spacing: 1px;
        HorizontalLayout {
            alignment: center;
            Icon { size: 15px; source: root.icon; colorize: active ? Backend.on-accent : Backend.fg; }
        }
        Text {
            text: label;
            color: active ? Backend.on-accent : Backend.fg;
            font-size: 9px;
            horizontal-alignment: center;
        }
    }
    TouchArea { clicked => { root.clicked(); } }
}

// A compact toolbar toggle: an icon over a tiny caption, tinted when active.
component BarToggle inherits Rectangle {
    in property <image> icon;
    in property <string> caption;
    in property <bool> active;
    callback clicked();
    width: 42px;
    // Active toggles get a filled pill so on/off reads at a glance, not just a tint.
    border-radius: 5px;
    background: root.active ? Backend.selection : (ta.has-hover ? Backend.hover : transparent);
    ta := TouchArea { clicked => { root.clicked(); } }
    VerticalLayout {
        alignment: center;
        spacing: 1px;
        HorizontalLayout {
            alignment: center;
            Image {
                width: 16px;
                height: 16px;
                image-fit: contain;
                source: root.icon;
                colorize: root.active ? Backend.accent : Backend.gutter-fg;
            }
        }
        Text {
            text: root.caption;
            font-size: 9px;
            horizontal-alignment: center;
            color: root.active ? Backend.accent : Backend.gutter-fg;
        }
    }
}

component Divider inherits Rectangle {
    width: 1px;
    background: Backend.divider;
}

// A fully theme-driven dropdown (the std-widgets ComboBox draws a fixed white
// border that ignores our palette). Supports both index- and value-bound use.
component ThemedCombo inherits Rectangle {
    in property <[string]> model;
    in-out property <int> current-index: 0;
    in-out property <string> current-value;
    callback selected(string);
    property <string> display: root.current-value != ""
        ? root.current-value
        : (root.model.length > 0 ? root.model[root.current-index] : "");
    height: 28px;
    border-radius: 5px;
    border-width: 1px;
    border-color: Backend.divider;
    background: Backend.bg;
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        Text {
            text: root.display;
            color: Backend.fg;
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        VerticalLayout {
            alignment: center;
            Image {
                width: 12px;
                height: 12px;
                image-fit: contain;
                source: @image-url("icons/chevron-down.svg");
                colorize: Backend.gutter-fg;
            }
        }
    }
    TouchArea { clicked => { popup.show(); } }
    popup := PopupWindow {
        x: 0;
        y: root.height + 2px;
        // At least the combo width, but grow to fit longer entries (repo paths,
        // branch / theme names) instead of clipping them.
        min-width: root.width;
        Rectangle {
            background: Backend.panel-bg;
            border-width: 1px;
            border-color: Backend.divider;
            border-radius: 5px;
            VerticalLayout {
                padding: 2px;
                for item[i] in root.model : Rectangle {
                    height: 26px;
                    background: itouch.has-hover ? Backend.hover : transparent;
                    border-radius: 3px;
                    itouch := TouchArea {
                        clicked => {
                            root.current-index = i;
                            root.current-value = item;
                            root.selected(item);
                        }
                    }
                    Text {
                        x: 8px;
                        text: item;
                        color: Backend.fg;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

// ---- the option bar --------------------------------------------------------

component OptionBar inherits Rectangle {
    height: 42px;
    background: Backend.panel-bg;
    Rectangle { y: parent.height - 1px; height: 1px; background: Backend.divider; }

    HorizontalLayout {
        padding: 6px;
        spacing: 8px;
        alignment: start;

        // View mode — icon + caption segments.
        Rectangle {
            border-radius: 5px;
            border-width: 1px;
            border-color: Backend.divider;
            clip: true;
            HorizontalLayout {
                spacing: 0px;
                SegToggle {
                    label: "Split";
                    icon: @image-url("icons/columns-2.svg");
                    active: DiffOptions.side-by-side;
                    clicked => { DiffOptions.side-by-side = true; DiffOptions.relayout(); }
                }
                Divider {}
                SegToggle {
                    label: "Unified";
                    icon: @image-url("icons/rows-2.svg");
                    active: !DiffOptions.side-by-side;
                    clicked => { DiffOptions.side-by-side = false; DiffOptions.relayout(); }
                }
            }
        }

        // Layout toggles (relayout only).
        BarToggle {
            icon: @image-url("icons/wrap-text.svg");
            caption: "Wrap";
            active: DiffOptions.word-wrap;
            clicked => { DiffOptions.word-wrap = !DiffOptions.word-wrap; DiffOptions.relayout(); }
        }
        BarToggle {
            icon: @image-url("icons/hash.svg");
            caption: "Lines";
            active: DiffOptions.show-line-numbers;
            clicked => { DiffOptions.show-line-numbers = !DiffOptions.show-line-numbers; DiffOptions.relayout(); }
        }

        Divider {}

        // Diff-content toggles (re-diff).
        BarToggle {
            icon: @image-url("icons/space.svg");
            caption: "WS";
            active: DiffOptions.ignore-whitespace;
            clicked => { DiffOptions.ignore-whitespace = !DiffOptions.ignore-whitespace; DiffOptions.rediff(); }
        }
        BarToggle {
            icon: @image-url("icons/braces.svg");
            caption: "Tokens";
            active: DiffOptions.token-granularity;
            clicked => { DiffOptions.token-granularity = !DiffOptions.token-granularity; DiffOptions.rediff(); }
        }
        BarToggle {
            icon: @image-url("icons/palette.svg");
            caption: "Syntax";
            active: DiffOptions.syntax-highlight;
            clicked => { DiffOptions.syntax-highlight = !DiffOptions.syntax-highlight; DiffOptions.rediff(); }
        }

        Divider {}

        // Less-frequent diff settings (context, algorithm, base ref) in a pop-out.
        more-btn := Rectangle {
            width: 42px;
            more-ta := TouchArea { clicked => { more-popup.show(); } }
            VerticalLayout {
                alignment: center;
                spacing: 1px;
                HorizontalLayout {
                    alignment: center;
                    Image {
                        width: 16px;
                        height: 16px;
                        image-fit: contain;
                        source: @image-url("icons/sliders-horizontal.svg");
                        colorize: more-ta.has-hover ? Backend.fg : Backend.gutter-fg;
                    }
                }
                Text {
                    text: "More";
                    font-size: 9px;
                    horizontal-alignment: center;
                    color: Backend.gutter-fg;
                }
            }
            more-popup := PopupWindow {
                x: 0;
                y: parent.height + 4px;
                // Give the popup window an explicit width matching its content, so
                // its outside-click region covers the whole panel — otherwise the
                // right edge of the last button lies outside the popup bounds and
                // clicking there is treated as an outside click (and dismisses it).
                width: 230px;
                close-policy: PopupClosePolicy.close-on-click-outside;
                Rectangle {
                    width: 100%;
                    background: Backend.panel-bg;
                    border-width: 1px;
                    border-color: Backend.divider;
                    border-radius: 6px;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 12px;
                        // Context lines.
                        HorizontalLayout {
                            spacing: 6px;
                            Text { text: "Context"; color: Backend.fg; vertical-alignment: center; horizontal-stretch: 1; }
                            Button {
                                text: "-";
                                clicked => {
                                    if (DiffOptions.context-lines > 0) {
                                        DiffOptions.context-lines -= 1;
                                        DiffOptions.rediff();
                                    }
                                }
                            }
                            Text {
                                text: DiffOptions.context-lines;
                                color: Backend.fg;
                                width: 20px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Button {
                                text: "+";
                                clicked => { DiffOptions.context-lines += 1; DiffOptions.rediff(); }
                            }
                        }
                        // Tab width (how far a tab is expanded in the diff).
                        HorizontalLayout {
                            spacing: 6px;
                            Text { text: "Tab width"; color: Backend.fg; vertical-alignment: center; horizontal-stretch: 1; }
                            Button {
                                text: "-";
                                clicked => {
                                    Backend.tab-width = max(1, Backend.tab-width - 1);
                                    Backend.set-tab-width(Backend.tab-width);
                                }
                            }
                            Text {
                                text: "\{Backend.tab-width}";
                                color: Backend.fg;
                                width: 20px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            Button {
                                text: "+";
                                clicked => {
                                    Backend.tab-width = min(16, Backend.tab-width + 1);
                                    Backend.set-tab-width(Backend.tab-width);
                                }
                            }
                        }
                        // Algorithm — radio-style rows (avoids a popup inside a popup).
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "ALGORITHM"; color: Backend.gutter-fg; font-size: 11px; }
                            for alg[i] in ["Patience", "Myers-greedy", "Myers-linear"] : Rectangle {
                                height: 26px;
                                border-radius: 4px;
                                background: i == DiffOptions.algorithm
                                    ? Backend.selection
                                    : (algta.has-hover ? Backend.hover : transparent);
                                algta := TouchArea {
                                    clicked => { DiffOptions.algorithm = i; DiffOptions.rediff(); }
                                }
                                Text {
                                    x: 8px;
                                    text: alg;
                                    color: Backend.fg;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Compare against an arbitrary base ref (blank = HEAD).
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "COMPARE AGAINST REF"; color: Backend.gutter-fg; font-size: 11px; }
                            LineEdit {
                                placeholder-text: "vs ref (HEAD)";
                                edited => { Backend.set-base-ref(self.text); }
                            }
                        }
                    }
                }
            }
        }
    }
}

// ---- the repository sidebar ------------------------------------------------

component SectionLabel inherits Text {
    color: Backend.gutter-fg;
    font-size: 11px;
}

// A self-drawn context menu (a PopupWindow we fully control), positioned at the
// cursor by the row that opens it. `items` labels the rows; "-" is a separator.
// Avoids ContextMenuArea, whose auto right-click trigger swallowed the click before
// the row could select itself.
component MenuPopup inherits PopupWindow {
    in property <[string]> items;
    callback activated(int);
    // The popup needs a definite width or its content Rectangle has nothing to fill
    // and the menu renders transparent.
    width: 210px;
    Rectangle {
        background: Backend.panel-bg;
        border-width: 1px;
        border-color: Backend.divider;
        border-radius: 6px;
        drop-shadow-blur: 10px;
        drop-shadow-color: #00000066;
        VerticalLayout {
            padding: 4px;
            for it[i] in items : Rectangle {
                height: it == "-" ? 9px : 26px;
                border-radius: 4px;
                background: (it != "-" && row-ta.has-hover) ? Backend.hover : transparent;
                row-ta := TouchArea {
                    enabled: it != "-";
                    clicked => { root.activated(i); root.close(); }
                }
                if it == "-" : Rectangle {
                    width: parent.width - 16px;
                    height: 1px;
                    background: Backend.divider;
                }
                if it != "-" : Text {
                    x: 10px;
                    text: it;
                    color: Backend.fg;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
        }
    }
}

// Left sidebar: repo picker, changed-files list, and the commit bar.
component FilesPanel inherits Rectangle {
    width: Backend.sidebar-width;
    background: Backend.panel-bg;
    // Transient disclosure state: reveal the open-a-repo fields / the file filter.
    property <bool> show-open: false;
    property <bool> show-filter: false;
    // Context of the right-clicked row + cursor position, for the shared menu below.
    property <string> ctx-path;
    property <string> ctx-name;
    property <bool> ctx-staged;
    property <length> ctx-mx;
    property <length> ctx-my;
    // Divider on the panel's right edge (it sits on the left side of the window).
    Rectangle { x: parent.width - 1px; width: 1px; background: Backend.divider; }

    // Shared right-click menu (a popup can't be repeated inside the file `for`).
    fmenu := MenuPopup {
        x: root.ctx-mx;
        y: root.ctx-my;
        // Right-click already selects + shows the file's diff, so no "View diff".
        items: [root.ctx-staged ? "Unstage" : "Stage", "Discard changes…", "-",
                "Open file", "Reveal in Explorer", "-",
                "Copy path", "Copy name"];
        activated(i) => {
            if (i == 0) {
                if (root.ctx-staged) { Backend.unstage-file(root.ctx-path); }
                else { Backend.stage-file(root.ctx-path); }
            }
            if (i == 1) { Backend.confirm-discard = root.ctx-path; }
            if (i == 3) { Backend.open-file(root.ctx-path); }
            if (i == 4) { Backend.reveal-file(root.ctx-path); }
            if (i == 6) { Backend.copy-to-clipboard(root.ctx-path); }
            if (i == 7) { Backend.copy-to-clipboard(root.ctx-name); }
        }
    }

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        // Repo picker: the combo switches repos; the folder icon reveals the
        // open-a-new-repo fields; the gear opens settings.
        HorizontalLayout {
            spacing: 6px;
            ThemedCombo {
                horizontal-stretch: 1;
                model: Backend.repo-names;
                selected(v) => { Backend.select-repo-index(self.current-index); }
            }
            open-toggle := Rectangle {
                width: 16px;
                open-ta := TouchArea { clicked => { root.show-open = !root.show-open; } }
                Image {
                    width: 16px;
                    height: 16px;
                    image-fit: contain;
                    source: @image-url("icons/folder-plus.svg");
                    colorize: root.show-open || open-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                }
            }
            gear := Rectangle {
                width: 16px;
                gear-ta := TouchArea { clicked => { Backend.show-settings = true; } }
                Image {
                    width: 16px;
                    height: 16px;
                    image-fit: contain;
                    source: @image-url("icons/settings.svg");
                    colorize: gear-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                }
            }
        }
        // Open a different repo — hidden until the folder icon is clicked, then
        // collapses again once a repo is chosen.
        if root.show-open : VerticalLayout {
            spacing: 6px;
            HorizontalLayout {
                spacing: 4px;
                path-input := LineEdit {
                    placeholder-text: "/path/to/repo";
                    horizontal-stretch: 1;
                    init => { self.focus(); }
                    accepted => { Backend.open-repo(self.text); root.show-open = false; }
                }
                Button { text: "Open"; clicked => { Backend.open-repo(path-input.text); root.show-open = false; } }
            }
            Button {
                text: "Browse…";
                icon: @image-url("icons/folder-open.svg");
                colorize-icon: true;
                clicked => { Backend.browse-repo(); root.show-open = false; }
            }
        }
        if Backend.branch != "" : HorizontalLayout {
            spacing: 6px;
            Icon {
                size: 14px;
                source: @image-url("icons/git-branch.svg");
                colorize: Backend.accent;
            }
            // Branch list + checkout (switches on selection).
            ThemedCombo {
                horizontal-stretch: 1;
                model: Backend.branch-names;
                current-value: Backend.branch;
                selected(v) => { Backend.checkout-branch(v); }
            }
        }

        // CHANGES header with a live count and a loading spinner.
        HorizontalLayout {
            spacing: 6px;
            SectionLabel {
                text: "CHANGES (\{Backend.files.length})";
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            // Toggle the file-filter field below.
            search-btn := Rectangle {
                width: 16px;
                search-ta := TouchArea {
                    clicked => {
                        root.show-filter = !root.show-filter;
                        if (!root.show-filter) { Backend.filter-files(""); }
                    }
                }
                Image {
                    width: 13px;
                    height: 13px;
                    image-fit: contain;
                    source: @image-url("icons/search.svg");
                    colorize: root.show-filter || search-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                }
            }
            // Toggle folder grouping vs staged/unstaged sections.
            group-btn := Rectangle {
                width: 16px;
                height: 16px;
                group-ta := TouchArea {
                    clicked => {
                        Backend.group-by-folder = !Backend.group-by-folder;
                        Backend.regroup-files();
                    }
                }
                Image {
                    width: 13px;
                    height: 13px;
                    image-fit: contain;
                    source: @image-url("icons/folder-open.svg");
                    colorize: Backend.group-by-folder
                        ? Backend.accent
                        : (group-ta.has-hover ? Backend.accent : Backend.gutter-fg);
                }
            }
            // Re-scan the working tree without reopening the repo (also Cmd/Ctrl-R).
            refresh-btn := Rectangle {
                width: 16px;
                height: 16px;
                refresh-ta := TouchArea { clicked => { Backend.refresh(); } }
                Image {
                    width: 13px;
                    height: 13px;
                    image-fit: contain;
                    source: @image-url("icons/refresh-cw.svg");
                    colorize: refresh-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                }
            }
            if Backend.loading : Rectangle {
                width: 13px;
                property <angle> ang: 0deg;
                Timer {
                    interval: 16ms;
                    running: true;
                    triggered => { parent.ang = parent.ang + 9deg; }
                }
                Image {
                    width: 13px;
                    height: 13px;
                    image-fit: contain;
                    source: @image-url("icons/loader-circle.svg");
                    colorize: Backend.gutter-fg;
                    rotation-angle: parent.ang;
                    rotation-origin-x: 6.5px;
                    rotation-origin-y: 6.5px;
                }
            }
        }

        // Filter the changes list — revealed by the search icon in the header.
        if root.show-filter : HorizontalLayout {
            spacing: 4px;
            Icon {
                size: 13px;
                source: @image-url("icons/search.svg");
                colorize: Backend.gutter-fg;
            }
            filter-input := LineEdit {
                placeholder-text: "Filter files";
                horizontal-stretch: 1;
                init => { self.focus(); }
                edited => { Backend.filter-files(self.text); }
            }
        }

        // Changed files fill the remaining height. Commit history lives in a
        // separate panel (CommitsPanel) on the other side of the diff.
        files-list := ListView {
            vertical-stretch: 1;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            // Scroll the keyboard-selected row into view when it changes.
                property <int> sel: Backend.file-sel-index;
                changed sel => {
                    if (self.sel >= 0) {
                        if (self.sel * 24px < -self.viewport-y) {
                            self.viewport-y = -self.sel * 24px;
                        } else if ((self.sel + 1) * 24px > -self.viewport-y + self.height) {
                            self.viewport-y = -((self.sel + 1) * 24px - self.height);
                        }
                    }
                }
                for f[fidx] in Backend.files : Rectangle {
                    height: 24px;
                    property <bool> selected: !f.is-section && f.path == Backend.current-file;
                    background: selected
                        ? Backend.selection
                        : (!f.is-section && touch.has-hover ? Backend.hover : transparent);
                    touch := TouchArea {
                        clicked => {
                            if (!f.is-section) {
                                Backend.file-sel-index = fidx;
                                Backend.select-file(f.path);
                            }
                        }
                        // Right-click selects the row, then opens the shared menu at
                        // the cursor (popups can't live inside a `for`, so one menu
                        // per panel is parameterised by the clicked row).
                        pointer-event(e) => {
                            if (!f.is-section
                                && e.button == PointerEventButton.right
                                && e.kind == PointerEventKind.down) {
                                Backend.file-sel-index = fidx;
                                Backend.select-file(f.path);
                                root.ctx-path = f.path;
                                root.ctx-name = f.name;
                                root.ctx-staged = f.staged;
                                root.ctx-mx = self.absolute-position.x - root.absolute-position.x + self.mouse-x;
                                root.ctx-my = self.absolute-position.y - root.absolute-position.y + self.mouse-y;
                                fmenu.show();
                            }
                        }
                    }

                    // Section / group header (staged-unstaged or folder).
                    if f.is-section : Text {
                        x: 6px;
                        text: f.name;
                        color: Backend.gutter-fg;
                        font-size: 11px;
                        vertical-alignment: center;
                    }

                    // A changed-file row.
                    if !f.is-section : HorizontalLayout {
                        padding-left: 6px + f.depth * 12px;
                        padding-right: 6px;
                        spacing: 6px;
                        StatusIcon { status: f.status; }
                        // Filename first so it stays visible; the directory is
                        // dimmed and elides as the row narrows.
                        Text {
                            text: f.name;
                            color: selected ? white : Backend.fg;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: f.dir;
                            color: Backend.gutter-fg;
                            overflow: elide;
                            horizontal-stretch: 1;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                        // Review-comment count badge (PR mode), vertically centred.
                        if f.comment-count > 0 : VerticalLayout {
                            alignment: center;
                            Rectangle {
                                height: 16px;
                                border-radius: 8px;
                                background: selected ? #ffffff : Backend.accent;
                                HorizontalLayout {
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    Text {
                                        text: f.comment-count;
                                        color: selected ? Backend.accent : Backend.on-accent;
                                        font-size: 10px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        if f.staged : Rectangle {
                            width: 8px;
                            Rectangle {
                                width: 6px;
                                height: 6px;
                                border-radius: 3px;
                                background: #73c991;
                            }
                        }
                        // Per-file actions: stage/unstage toggle + discard.
                        Rectangle {
                            width: 16px;
                            stage-ta := TouchArea {
                                clicked => {
                                    if (f.staged) { Backend.unstage-file(f.path); }
                                    else { Backend.stage-file(f.path); }
                                }
                            }
                            Image {
                                width: 13px;
                                height: 13px;
                                source: f.staged
                                    ? @image-url("icons/circle-minus.svg")
                                    : @image-url("icons/circle-plus.svg");
                                colorize: stage-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                            }
                        }
                        Rectangle {
                            width: 16px;
                            discard-ta := TouchArea {
                                clicked => { Backend.confirm-discard = f.path; }
                            }
                            Image {
                                width: 13px;
                                height: 13px;
                                source: @image-url("icons/undo.svg");
                                colorize: discard-ta.has-hover ? #f48771 : Backend.gutter-fg;
                            }
                        }
                    }
                }
            }

        // Commit bar — only while something is staged (nothing to commit otherwise),
        // which also hands its space back to the list when idle.
        if Backend.on-working-tree && Backend.staged-count > 0 : VerticalLayout {
            spacing: 6px;
            // The body editor stays hidden for quick one-line commits and unfolds
            // once you engage the subject (focus it or type), matching git's
            // subject / blank line / body convention.
            property <bool> expanded: commit-subject.has-focus || commit-body.has-focus
                || commit-subject.text != "" || commit-body.text != "";
            commit-subject := LineEdit {
                placeholder-text: "Summary";
                // Enter in the summary drops into the body rather than committing,
                // so multi-line messages are easy to write.
                accepted => { commit-body.focus(); }
            }
            commit-body := TextArea {
                placeholder-text: "Description (optional)";
                visible: parent.expanded;
                height: parent.expanded ? 76px : 0px;
                animate height { duration: 120ms; easing: ease-out; }
            }
            HorizontalLayout {
                spacing: 6px;
                amend-cb := CheckBox { text: "Amend"; }
                Rectangle { horizontal-stretch: 1; }
                Button {
                    text: "Commit (\{Backend.staged-count})";
                    enabled: commit-subject.text != "";
                    clicked => {
                        // git treats line 1 as the subject and the rest (after a
                        // blank line) as the body.
                        Backend.commit(commit-body.text != ""
                            ? commit-subject.text + "\n\n" + commit-body.text
                            : commit-subject.text, amend-cb.checked);
                        commit-subject.text = "";
                        commit-body.text = "";
                    }
                }
            }
        }
    }
}

// A collapsible "shelf" header: a chevron + title (+ optional count) that toggles
// the shelf's `collapsed` state. The shelf's content is rendered by the caller,
// gated on `collapsed`.
component ShelfHeader inherits Rectangle {
    in property <string> title;
    in property <string> count;
    in-out property <bool> collapsed: false;
    height: 26px;
    ta := TouchArea { clicked => { root.collapsed = !root.collapsed; } }
    HorizontalLayout {
        padding-left: 2px;
        padding-right: 4px;
        spacing: 6px;
        VerticalLayout {
            alignment: center;
            Icon {
                size: 12px;
                source: @image-url("icons/chevron-down.svg");
                colorize: ta.has-hover ? Backend.accent : Backend.gutter-fg;
                rotation: root.collapsed ? -90deg : 0deg;
            }
        }
        Text {
            text: root.title;
            color: ta.has-hover ? Backend.accent : Backend.gutter-fg;
            font-size: 10px;
            font-weight: 700;
            vertical-alignment: center;
        }
        Rectangle { horizontal-stretch: 1; }
        if root.count != "" : Text {
            text: root.count;
            color: Backend.gutter-fg;
            font-size: 10px;
            vertical-alignment: center;
        }
    }
}

// Right sidebar: commit history, lazy-loaded as you scroll.
component CommitsPanel inherits Rectangle {
    in property <length> panel-width;
    width: panel-width;
    background: Backend.panel-bg;
    // Right-clicked commit's data + cursor position, for the shared menu below.
    property <string> ctx-oid;
    property <string> ctx-short;
    property <string> ctx-summary;
    property <length> ctx-mx;
    property <length> ctx-my;
    // Divider on the panel's left edge (it sits on the right side of the window).
    Rectangle { x: 0; width: 1px; background: Backend.divider; }

    // Shared right-click menu (a popup can't be repeated inside the commit `for`).
    cmenu := MenuPopup {
        x: root.ctx-mx;
        y: root.ctx-my;
        // Right-click already selects + shows the commit, so no redundant "View".
        items: ["Diff working tree against this", "-",
                "Copy SHA", "Copy short SHA", "Copy summary", "-",
                "Checkout commit", "Create branch here…"];
        activated(i) => {
            if (i == 0) { Backend.set-base-ref(root.ctx-oid); }
            if (i == 2) { Backend.copy-to-clipboard(root.ctx-oid); }
            if (i == 3) { Backend.copy-to-clipboard(root.ctx-short); }
            if (i == 4) { Backend.copy-to-clipboard(root.ctx-summary); }
            if (i == 6) { Backend.checkout-commit(root.ctx-oid); }
            if (i == 7) { Backend.create-branch-oid = root.ctx-oid; }
        }
    }

    // User-toggled shelf state (the PR-list shelf's collapse is driven from C++ via
    // Backend.pr-list-collapsed when a PR opens/closes).
    property <bool> sh-commits-collapsed: false;
    property <bool> sh-comments-collapsed: false;

    VerticalLayout {
        padding: 8px;
        spacing: 4px;

        // PR detail header (only inside a PR): title + a Close control that exits
        // the review to the working tree. (Switch PRs by expanding the shelf below.)
        if Backend.pr-open : HorizontalLayout {
            spacing: 6px;
            Text {
                text: Backend.pr-title;
                color: Backend.fg;
                font-size: 13px;
                font-weight: 600;
                overflow: elide;
                horizontal-stretch: 1;
            }
            comment-ta := TouchArea {
                width: 68px;
                clicked => { Backend.open-composer(true); }
                Text {
                    text: "Comment";
                    color: comment-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                    font-size: 11px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
            close-ta := TouchArea {
                width: 40px;
                clicked => { Backend.close-pr(); }
                Text {
                    text: "Close";
                    color: close-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                    font-size: 11px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }
        if Backend.pr-open : Text {
            text: Backend.pr-subtitle;
            color: Backend.gutter-fg;
            font-size: 10px;
            overflow: elide;
        }
        // Diffstat + quick actions (Open in browser / Copy link).
        if Backend.pr-open : HorizontalLayout {
            spacing: 8px;
            Text {
                text: Backend.pr-stat;
                color: Backend.gutter-fg;
                font-size: 10px;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }
            open-ext-ta := TouchArea {
                width: 36px;
                clicked => { if (Backend.pr-url != "") { Backend.open-url(Backend.pr-url); } }
                Text {
                    text: "Open";
                    color: open-ext-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                    font-size: 10px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
            copy-link-ta := TouchArea {
                width: 34px;
                clicked => { if (Backend.pr-url != "") { Backend.copy-to-clipboard(Backend.pr-url); } }
                Text {
                    text: "Copy";
                    color: copy-link-ta.has-hover ? Backend.accent : Backend.gutter-fg;
                    font-size: 10px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }

        // ---- Shelf: Pull requests (collapses when a PR opens) ----
        if Backend.has-bitbucket : ShelfHeader {
            title: "PULL REQUESTS";
            collapsed <=> Backend.pr-list-collapsed;
        }
        if Backend.has-bitbucket && !Backend.pr-list-collapsed : ListView {
            vertical-stretch: 1;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            // Lazy pagination: fetch the next page as the list nears the bottom.
            changed viewport-y => {
                if (Backend.more-prs && !Backend.loading-prs
                    && -self.viewport-y + self.visible-height >= self.viewport-height - 150px) {
                    Backend.load-more-prs();
                }
            }
            for pr in Backend.pull-requests : Rectangle {
                height: pr.is-section ? 22px : 52px;
                background: (!pr.is-section && pr-ta.has-hover) ? Backend.hover : transparent;
                pr-ta := TouchArea {
                    enabled: !pr.is-section;
                    clicked => { Backend.open-pr(pr.id); }
                }
                // Group header row.
                if pr.is-section : Text {
                    x: 8px;
                    width: parent.width - 12px;
                    height: 100%;
                    text: pr.title;
                    color: Backend.gutter-fg;
                    font-size: 10px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                // Pull-request row: author avatar + title/draft + meta + relative time.
                if !pr.is-section : HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 6px;
                    padding-top: 5px;
                    padding-bottom: 5px;
                    spacing: 8px;
                    // Author avatar (pre-masked circular in C++) or initials fallback.
                    Rectangle {
                        width: 26px;
                        VerticalLayout {
                            alignment: center;
                            if pr.avatar.width > 0 : Image {
                                width: 24px;
                                height: 24px;
                                image-rendering: smooth;
                                source: pr.avatar;
                            }
                            if pr.avatar.width == 0 : Rectangle {
                                width: 24px;
                                height: 24px;
                                border-radius: 12px;
                                background: pr.tint;
                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: pr.initials;
                                    color: #ffffff;
                                    font-size: 11px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                    VerticalLayout {
                        HorizontalLayout {
                            spacing: 5px;
                            Text {
                                text: pr.title;
                                color: Backend.fg;
                                font-size: 12px;
                                overflow: elide;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                            if pr.draft : Rectangle {
                                border-radius: 3px;
                                background: Backend.divider;
                                HorizontalLayout {
                                    padding-left: 4px;
                                    padding-right: 4px;
                                    Text {
                                        text: "draft";
                                        color: Backend.gutter-fg;
                                        font-size: 9px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            Text {
                                text: "#" + pr.id + "  " + pr.source + " → " + pr.dest
                                      + (pr.comments > 0 ? "  ·  " + pr.comments + " 💬" : "");
                                color: Backend.gutter-fg;
                                font-size: 10px;
                                overflow: elide;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                            Text {
                                text: pr.updated-rel;
                                color: Backend.gutter-fg;
                                font-size: 10px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
        if Backend.has-bitbucket && !Backend.pr-list-collapsed && Backend.loading-prs : Text {
            text: "Loading pull requests…";
            color: Backend.gutter-fg;
            font-size: 11px;
        }
        if Backend.has-bitbucket && !Backend.pr-list-collapsed && !Backend.loading-prs && Backend.pull-requests.length == 0 : Text {
            text: "No open pull requests";
            color: Backend.gutter-fg;
            font-size: 11px;
        }

        // ---- Shelf: Comments (inside a PR, when it has any) ----
        if Backend.pr-open && Backend.pr-comments.length > 0 : ShelfHeader {
            title: "COMMENTS";
            count: "\{Backend.pr-comments.length}";
            collapsed <=> root.sh-comments-collapsed;
        }
        if Backend.pr-open && Backend.pr-comments.length > 0 && !root.sh-comments-collapsed : ListView {
            vertical-stretch: 1;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            for cm in Backend.pr-comments : Rectangle {
                height: 46px;
                border-radius: 5px;
                background: cm-ta.has-hover && cm.path != "" ? Backend.hover : transparent;
                cm-ta := TouchArea {
                    mouse-cursor: cm.path != "" ? pointer : default;
                    clicked => { Backend.open-comment(cm.path, cm.line, cm.side); }
                }
                HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 6px;
                    padding-top: 5px;
                    padding-bottom: 5px;
                    VerticalLayout {
                        Text {
                            text: cm.author + "  ·  " + cm.location;
                            color: Backend.gutter-fg;
                            font-size: 10px;
                            overflow: elide;
                        }
                        Text {
                            text: cm.snippet;
                            color: Backend.fg;
                            font-size: 12px;
                            overflow: elide;
                        }
                    }
                }
            }
        }

        // Working-tree entry: selecting it leaves any historical commit and shows
        // the uncommitted changes (and, once something is staged, the commit box).
        if !Backend.pr-open : Rectangle {
            height: 38px;
            border-radius: 5px;
            background: Backend.on-working-tree
                        ? Backend.selection
                        : (wtouch.has-hover ? Backend.hover : transparent);
            wtouch := TouchArea { clicked => { Backend.select-working-tree(); } }
            HorizontalLayout {
                padding-left: 6px;
                padding-right: 6px;
                spacing: 6px;
                Rectangle {
                    width: 14px;
                    // A filled dot marks the live working tree (vs a commit's node).
                    Rectangle {
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: Backend.changes-count > 0 ? Backend.accent : Backend.gutter-fg;
                    }
                }
                VerticalLayout {
                    padding-top: 4px;
                    padding-bottom: 4px;
                    Text {
                        text: "Uncommitted changes";
                        color: Backend.fg;
                        overflow: elide;
                        font-size: 12px;
                    }
                    Text {
                        text: Backend.changes-count > 0
                              ? "\{Backend.changes-count} changed file(s)"
                              : "working tree clean";
                        color: Backend.gutter-fg;
                        font-size: 10px;
                    }
                }
            }
        }
        // ---- Shelf: Commits (PR commits inside a PR, else local history) ----
        ShelfHeader {
            title: Backend.pr-open ? "COMMITS" : "RECENT COMMITS";
            collapsed <=> root.sh-commits-collapsed;
        }
        // "Full diff" row (PR mode): the aggregate PR diff, selected by default.
        // Selecting a commit below narrows to that commit; this returns here.
        if Backend.pr-open && !root.sh-commits-collapsed : Rectangle {
            height: 38px;
            background: Backend.commit-sel-index == -1
                        ? Backend.selection
                        : (fulltouch.has-hover ? Backend.hover : transparent);
            fulltouch := TouchArea { clicked => { Backend.show-pr-aggregate(); } }
            HorizontalLayout {
                padding-left: 6px;
                padding-right: 6px;
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "Full diff";
                        color: Backend.fg;
                        font-size: 12px;
                    }
                    Text {
                        text: "all changes in this PR";
                        color: Backend.gutter-fg;
                        font-size: 10px;
                        overflow: elide;
                    }
                }
            }
        }
        if !root.sh-commits-collapsed : commits-list := ListView {
            vertical-stretch: 1;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            // Lazy-load: fetch the next page as the list nears the bottom.
            changed viewport-y => {
                if (Backend.more-commits && !Backend.loading-commits
                    && -self.viewport-y + self.visible-height >= self.viewport-height - 200px) {
                    Backend.load-more-commits();
                }
            }
            // Scroll the keyboard-selected commit into view when it changes.
            property <int> sel: Backend.commit-sel-index;
            changed sel => {
                if (self.sel >= 0) {
                    if (self.sel * 38px < -self.viewport-y) {
                        self.viewport-y = -self.sel * 38px;
                    } else if ((self.sel + 1) * 38px > -self.viewport-y + self.height) {
                        self.viewport-y = -((self.sel + 1) * 38px - self.height);
                    }
                }
            }
            for c[cidx] in Backend.commits : Rectangle {
                height: 38px;
                background: cidx == Backend.commit-sel-index
                            ? Backend.selection
                            : (ctouch.has-hover ? Backend.hover : transparent);
                ctouch := TouchArea {
                    clicked => {
                        Backend.commit-sel-index = cidx;
                        Backend.select-commit(c.oid);
                    }
                    // Right-click selects the commit, then opens the shared menu at
                    // the cursor (one menu per panel, parameterised by the row).
                    pointer-event(e) => {
                        if (e.button == PointerEventButton.right && e.kind == PointerEventKind.down) {
                            Backend.commit-sel-index = cidx;
                            Backend.select-commit(c.oid);
                            root.ctx-oid = c.oid;
                            root.ctx-short = c.short-oid;
                            root.ctx-summary = c.summary;
                            root.ctx-mx = self.absolute-position.x - root.absolute-position.x + self.mouse-x;
                            root.ctx-my = self.absolute-position.y - root.absolute-position.y + self.mouse-y;
                            cmenu.show();
                        }
                    }
                }
                HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 6px;
                    spacing: 6px;
                    Icon {
                        size: 14px;
                        source: @image-url("icons/git-commit.svg");
                        colorize: Backend.gutter-fg;
                    }
                    VerticalLayout {
                        padding-top: 4px;
                        padding-bottom: 4px;
                        Text {
                            text: c.summary;
                            color: Backend.fg;
                            overflow: elide;
                            font-size: 12px;
                        }
                        Text {
                            text: c.short-oid;
                            color: Backend.gutter-fg;
                            font-family: Backend.mono-font;
                            font-size: 10px;
                        }
                    }
                }
            }
        }
        if Backend.loading-commits : Text {
            text: "Loading…";
            color: Backend.gutter-fg;
            font-size: 11px;
            horizontal-alignment: center;
        }
    }
}

// ---- settings panel --------------------------------------------------------

component SettingsPanel inherits Rectangle {
    // Dim backdrop over the whole window; a click outside the card closes it.
    background: #00000099;
    visible: Backend.show-settings;
    backdrop-ta := TouchArea { clicked => { Backend.show-settings = false; } }

    // Centered card.
    Rectangle {
        width: 440px;
        height: card.preferred-height;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Backend.panel-bg;
        border-radius: 10px;
        border-width: 1px;
        border-color: Backend.divider;
        // Swallow clicks so they don't fall through to the backdrop.
        TouchArea {}

        card := VerticalLayout {
            padding: 22px;
            spacing: 16px;

            Text { text: "Settings"; color: Backend.fg; font-size: 17px; font-weight: 600; }

            // Diff font: curated dropdown + free-text for any installed family.
            VerticalLayout {
                spacing: 6px;
                Text { text: "DIFF FONT"; color: Backend.gutter-fg; font-size: 11px; }
                ThemedCombo {
                    model: Backend.font-choices;
                    current-value: Backend.mono-font;
                    selected(v) => { Backend.mono-font = v; }
                }
                LineEdit {
                    placeholder-text: "or type any installed family…";
                    text: Backend.mono-font;
                    edited => { Backend.mono-font = self.text; }
                }
            }

            // Font size stepper (tab width moved to the toolbar's diff-options popup).
            HorizontalLayout {
                spacing: 8px;
                Text { text: "Size"; color: Backend.fg; vertical-alignment: center; }
                Button { text: "-"; clicked => { Backend.font-size = max(8, Backend.font-size - 1); } }
                Text {
                    text: "\{Backend.font-size}";
                    color: Backend.fg;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    width: 24px;
                }
                Button { text: "+"; clicked => { Backend.font-size = min(32, Backend.font-size + 1); } }
                Rectangle { horizontal-stretch: 1; }
            }

            // Theme (applied live).
            VerticalLayout {
                spacing: 6px;
                Text { text: "THEME"; color: Backend.gutter-fg; font-size: 11px; }
                ThemedCombo {
                    model: Backend.theme-names;
                    current-value: Backend.theme-name;
                    selected(v) => { Backend.theme-name = v; Backend.set-theme(v); }
                }
            }

            // Pull-request review: open the Bitbucket connect dialog.
            VerticalLayout {
                spacing: 6px;
                Text { text: "PULL REQUESTS"; color: Backend.gutter-fg; font-size: 11px; }
                Button {
                    text: Backend.bitbucket-connected ? "Bitbucket — connected ✓" : "Connect Bitbucket…";
                    clicked => {
                        Backend.show-settings = false;
                        Backend.show-bitbucket = true;
                    }
                }
            }

            HorizontalLayout {
                alignment: end;
                Button { text: "Done"; clicked => { Backend.show-settings = false; } }
            }
        }
    }
}

// ---- Bitbucket connect dialog ----------------------------------------------

component BitbucketPanel inherits Rectangle {
    background: #00000099;
    visible: Backend.show-bitbucket;
    backdrop-ta := TouchArea { clicked => { Backend.show-bitbucket = false; } }

    Rectangle {
        width: 460px;
        height: card.preferred-height;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Backend.panel-bg;
        border-radius: 10px;
        border-width: 1px;
        border-color: Backend.divider;
        TouchArea {}  // swallow clicks so they don't dismiss via the backdrop

        card := VerticalLayout {
            padding: 22px;
            spacing: 14px;

            Text { text: "Connect Bitbucket"; color: Backend.fg; font-size: 17px; font-weight: 600; }
            Text {
                text: "Simplest: create a Bitbucket access token (Workspace or Repository settings → "
                    + "Access tokens) with the Pull requests: Read scope and paste it below, leaving "
                    + "Email blank. Alternatively use an Atlassian API token (id.atlassian.com) together "
                    + "with your account email. The token is stored in the OS credential vault, never "
                    + "in config.";
                color: Backend.gutter-fg;
                font-size: 11px;
                wrap: word-wrap;
            }

            VerticalLayout {
                spacing: 4px;
                Text { text: "WORKSPACE"; color: Backend.gutter-fg; font-size: 11px; }
                bb-ws := LineEdit { placeholder-text: "e.g. myteam"; }
            }
            VerticalLayout {
                spacing: 4px;
                Text { text: "REPOSITORY  (optional — tests an open-PR count)"; color: Backend.gutter-fg; font-size: 11px; }
                bb-repo := LineEdit { placeholder-text: "e.g. my-repo"; }
            }
            VerticalLayout {
                spacing: 4px;
                Text { text: "ATLASSIAN EMAIL  (leave blank for a Bitbucket access token)"; color: Backend.gutter-fg; font-size: 11px; }
                HorizontalLayout {
                    spacing: 6px;
                    bb-user := LineEdit { placeholder-text: "you@example.com — optional"; horizontal-stretch: 1; }
                    // Inserts "@" at the cursor for keyboard layouts where AltGr is
                    // dropped (Slint #6263). Re-focus the field first, then dispatch
                    // a synthetic key event: dispatch targets the focused item, and
                    // clicking the button had moved focus away (which is why nothing
                    // happened before).
                    Button {
                        text: "@";
                        clicked => {
                            bb-user.focus();
                            Backend.type-text("@");
                        }
                    }
                }
            }
            VerticalLayout {
                spacing: 4px;
                Text { text: "ACCESS / API TOKEN"; color: Backend.gutter-fg; font-size: 11px; }
                bb-pass := LineEdit { placeholder-text: "paste token"; password: true; }
            }

            if Backend.bitbucket-status != "" : Text {
                text: Backend.bitbucket-status;
                color: Backend.bitbucket-connected ? Backend.accent : Backend.fg;
                font-size: 12px;
                wrap: word-wrap;
            }

            HorizontalLayout {
                alignment: end;
                spacing: 8px;
                Button { text: "Close"; clicked => { Backend.show-bitbucket = false; } }
                Button {
                    text: Backend.bitbucket-connecting ? "Connecting…" : "Connect";
                    enabled: !Backend.bitbucket-connecting && bb-ws.text != "" && bb-pass.text != "";
                    clicked => {
                        Backend.connect-bitbucket(bb-ws.text, bb-repo.text, bb-user.text, bb-pass.text);
                    }
                }
            }
        }
    }
}

// ---- the window ------------------------------------------------------------

export component AppWindow inherits Window {
    title: "diffy";
    icon: @image-url("icons/app-icon.svg");
    // Drive the std-widgets palette (scrollbars etc.) from the active theme's
    // light/darkness so they stop looking dark on a light theme.
    property <bool> is-dark: Backend.dark;
    init => { Palette.color-scheme = Backend.dark ? ColorScheme.dark : ColorScheme.light; }
    changed is-dark => { Palette.color-scheme = is-dark ? ColorScheme.dark : ColorScheme.light; }
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 480px;
    min-height: 360px;
    background: Backend.bg;

    forward-focus: key-scope;
    key-scope := FocusScope {
        // Global keyboard navigation. LineEdits grab focus and consume their own
        // keys, so these only fire when no text field is focused.
        key-pressed(event) => {
            if (event.text == Key.Escape && Backend.show-settings) {
                Backend.show-settings = false;
                return accept;
            }
            if (event.text == Key.Escape && Backend.show-bitbucket) {
                Backend.show-bitbucket = false;
                return accept;
            }
            if (event.text == Key.Escape && Backend.show-find) {
                Backend.show-find = false;
                Backend.find-close();
                return accept;
            }
            if ((event.modifiers.control || event.modifiers.meta) && event.text == "f") {
                Backend.show-find = true;
                return accept;
            }
            if ((event.modifiers.control || event.modifiers.meta) && event.text == "c"
                && Backend.sel-anchor-row >= 0) {
                Backend.copy-selection();
                return accept;
            }
            if (event.text == Key.Escape && Backend.composer-open) {
                Backend.composer-open = false;
                return accept;
            }
            if (event.text == Key.Escape && Backend.sel-anchor-row >= 0) {
                Backend.sel-anchor-row = -1;
                Backend.sel-focus-row = -1;
                return accept;
            }
            if (event.text == "c" && Backend.pr-open && Backend.sel-anchor-row >= 0
                && !Backend.composer-open) {
                Backend.open-composer(false);
                return accept;
            }
            if (event.text == Key.UpArrow || event.text == "k") {
                Backend.navigate("up");
                return accept;
            }
            if (event.text == Key.DownArrow || event.text == "j") {
                Backend.navigate("down");
                return accept;
            }
            if (event.text == Key.Tab) {
                Backend.navigate("tab");
                return accept;
            }
            if (event.text == "n") {
                Backend.navigate("next-hunk");
                return accept;
            }
            if (event.text == "p") {
                Backend.navigate("prev-hunk");
                return accept;
            }
            if (event.text == Key.Return) {
                Backend.navigate("activate");
                return accept;
            }
            if ((event.modifiers.control || event.modifiers.meta) && event.text == "r") {
                Backend.refresh();
                return accept;
            }
            return reject;
        }

      content := Rectangle {
        // Files panel (left) and commits panel (right) collapse independently.
        property <bool> files-collapsed: false;
        property <bool> commits-collapsed: false;
        property <length> commits-width: 280px;
        HorizontalLayout {
        spacing: 0px;

        // LEFT: changed-files panel + its resize handle (grows as it drags right).
        if !content.files-collapsed : FilesPanel {}
        if !content.files-collapsed : Rectangle {
            width: 6px;
            background: Backend.panel-bg;
            files-handle := TouchArea {
                mouse-cursor: col-resize;
                moved => {
                    if (self.pressed) {
                        Backend.sidebar-width = clamp(
                            self.absolute-position.x - content.absolute-position.x
                                + self.mouse-x - 3px,
                            180px, content.width - 520px);
                    }
                }
            }
            Rectangle {
                x: 2px;
                width: 2px;
                background: files-handle.pressed || files-handle.has-hover
                            ? Backend.gutter-fg : transparent;
            }
        }

        VerticalLayout {
            spacing: 0px;
            horizontal-stretch: 1;
            // Let the centre shrink freely so the window resizes naturally. Without
            // this, the OptionBar's many controls (and a long file path) force a
            // large min-width on the whole window; overflowing controls just clip.
            min-width: 0px;

            // header strip
            Rectangle {
                height: 30px;
                background: Backend.bg;
                Rectangle { y: parent.height - 1px; height: 1px; background: Backend.divider; }
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;
                    // Collapse / expand the left (files) panel.
                    files-btn := Rectangle {
                        width: 20px;
                        files-ta := TouchArea {
                            clicked => { content.files-collapsed = !content.files-collapsed; }
                        }
                        Image {
                            width: 16px;
                            height: 16px;
                            image-fit: contain;
                            source: @image-url("icons/panel-left.svg");
                            colorize: content.files-collapsed
                                ? Backend.gutter-fg
                                : (files-ta.has-hover ? Backend.accent : Backend.fg);
                        }
                    }
                    Text {
                        text: Backend.current-file == "" ? "No file selected" : Backend.current-file;
                        color: Backend.current-file == "" ? Backend.gutter-fg : Backend.fg;
                        vertical-alignment: center;
                        font-family: Backend.mono-font;
                        font-size: 12px;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    // Collapse / expand the right (commits) panel.
                    commits-btn := Rectangle {
                        width: 20px;
                        commits-ta := TouchArea {
                            clicked => { content.commits-collapsed = !content.commits-collapsed; }
                        }
                        Image {
                            width: 16px;
                            height: 16px;
                            image-fit: contain;
                            source: @image-url("icons/panel-right.svg");
                            colorize: content.commits-collapsed
                                ? Backend.gutter-fg
                                : (commits-ta.has-hover ? Backend.accent : Backend.fg);
                        }
                    }
                }
            }

            OptionBar {}

            // The diff itself: a single virtualized ListView of full rows, so
            // only the visible rows are instantiated (large diffs stay fast).
            // Each row draws both sides with a centred divider in side-by-side
            // mode. Long lines clip at the cell edge unless word-wrap is on.
            diff-area := Rectangle {
                background: Backend.bg;
                vertical-stretch: 1;
                clip: true;

                // Measured monospace advance (logical px/column): the *content*
                // width of a 40-char sample / 40. Must use preferred-width — a
                // non-layout child's `width` fills the parent, which would make the
                // advance scale with the pane and the wrap column count constant.
                property <length> advance: calib.preferred-width / 40;
                property <length> overview-body-h: 120px;  // user-resizable overview height
                property <length> gut: DiffOptions.show-line-numbers ? 48px : 0px;
                // One diff cell's width at the *visible* pane width (mirrors
                // DiffRow.cellw). Pushed to C++ to derive the wrap column count.
                property <length> cellw: max(10px, DiffOptions.side-by-side
                    ? (self.width - 2 * gut - 1px) / 2
                    : (self.width - 2 * gut));
                changed cellw => { Backend.set-wrap-metrics(cellw / 1px, advance / 1px); }
                changed advance => {
                    Backend.set-wrap-metrics(cellw / 1px, advance / 1px);
                    Backend.char-advance = advance;  // for selection hit-testing
                }
                init => {
                    Backend.set-wrap-metrics(cellw / 1px, advance / 1px);
                    Backend.char-advance = advance;
                }

                // Hidden sample, used only to measure the font advance above.
                calib := Text {
                    opacity: 0;
                    text: "0000000000000000000000000000000000000000";
                    font-family: Backend.mono-font;
                    font-size: Backend.font-size * 1px;
                }

                // Diff column: an optional overview header (PR description in Full
                // diff, or the commit message in a commit view) above the diff.
                VerticalLayout {
                if Backend.overview-visible : Rectangle {
                    background: Backend.panel-bg;
                    Rectangle { y: parent.height - 1px; height: 1px; background: Backend.divider; }
                    VerticalLayout {
                        padding: 8px;
                        spacing: 5px;
                        Rectangle {
                            height: 20px;
                            ovhdr := TouchArea {
                                clicked => { Backend.overview-collapsed = !Backend.overview-collapsed; }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                VerticalLayout {
                                    alignment: center;
                                    Icon {
                                        size: 11px;
                                        source: @image-url("icons/chevron-down.svg");
                                        rotation: Backend.overview-collapsed ? -90deg : 0deg;
                                        colorize: ovhdr.has-hover ? Backend.accent : Backend.gutter-fg;
                                    }
                                }
                                Text {
                                    text: Backend.overview-title;
                                    color: Backend.fg;
                                    font-size: 13px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                Text {
                                    text: Backend.overview-subtitle;
                                    color: Backend.gutter-fg;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                            }
                        }
                        if !Backend.overview-collapsed && Backend.overview-body != "" : ov-scroll := ScrollView {
                            height: diff-area.overview-body-h;
                            // The viewport must be as tall as the (wrapped) text for
                            // vertical scrolling; otherwise it defaults to the view
                            // height and the text is clipped instead of scrolled.
                            viewport-width: ov-scroll.width - 14px;
                            viewport-height: ov-body.preferred-height;
                            // Read-only TextInput (not Text) so the description /
                            // commit message can be selected and copied (Ctrl/Cmd+C).
                            ov-body := TextInput {
                                width: ov-scroll.width - 14px;
                                text: Backend.overview-body;
                                color: Backend.fg;
                                font-size: 12px;
                                wrap: word-wrap;
                                single-line: false;
                                read-only: true;
                            }
                        }
                    }
                    // Drag the bottom edge to resize the overview body. Anchored to
                    // the band's bottom (a bare child would sit at y:0, over the header).
                    if !Backend.overview-collapsed && Backend.overview-body != "" : Rectangle {
                        height: 7px;
                        y: parent.height - self.height;
                        property <length> start-h;
                        property <length> start-y;
                        ovresize := TouchArea {
                            mouse-cursor: ns-resize;
                            pointer-event(e) => {
                                if (e.kind == PointerEventKind.down) {
                                    parent.start-h = diff-area.overview-body-h;
                                    parent.start-y = self.absolute-position.y + self.mouse-y;
                                }
                            }
                            moved => {
                                if (self.pressed) {
                                    diff-area.overview-body-h = clamp(
                                        parent.start-h + self.absolute-position.y + self.mouse-y
                                            - parent.start-y,
                                        40px, 480px);
                                }
                            }
                        }
                        Rectangle {
                            y: (parent.height - self.height) / 2;
                            height: 3px;
                            width: 40px;
                            x: (parent.width - self.width) / 2;
                            border-radius: 1px;
                            background: ovresize.pressed || ovresize.has-hover
                                        ? Backend.accent : Backend.divider;
                        }
                    }
                }
                Rectangle {
                    vertical-stretch: 1;
                if Backend.rows.length > 0 : diff-list := ListView {
                    // A ListView is a widget, not a layout, so it must be told
                    // to fill the (plain Rectangle) diff area explicitly.
                    width: 100%;
                    height: 100%;
                    // The diff never scrolls horizontally (it wraps or clips), so kill
                    // the horizontal scrollbar — the fluent style otherwise draws its
                    // track as a white strip across the bottom of the diff.
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    // Jump-to-hunk / comment ref: C++ computes the exact pixel
                    // offset (accounting for taller comment rows) and pushes it here.
                    property <float> scroll-to: Backend.diff-scroll-y;
                    changed scroll-to => {
                        if (self.scroll-to >= 0) {
                            self.viewport-y = -self.scroll-to * 1px;
                        }
                    }
                    // Rows fill the list width so they re-size (and re-split / re-wrap)
                    // live with the window. Long lines clip at the cell edge when wrap
                    // is off; turn on Wrap (or Unified) to see them in full.
                    for data[idx] in Backend.rows : DiffRow {
                        // Visible width (not full width) so the rows never exceed the
                        // viewport when the vertical scrollbar is present — otherwise a
                        // spurious horizontal scrollbar + corner box shows at the bottom.
                        width: diff-list.visible-width;
                        rowdata: data;
                        index: idx;
                        highlight: idx == Backend.find-current-row;
                    }
                }

                // empty state
                if Backend.rows.length == 0 : VerticalLayout {
                    alignment: center;
                    spacing: 12px;
                    Rectangle {
                        height: 44px;
                        Image {
                            width: 44px;
                            height: 44px;
                            image-fit: contain;
                            source: @image-url("icons/git-compare.svg");
                            colorize: Backend.gutter-fg;
                        }
                    }
                    Text {
                        text: Backend.diff-note != ""
                            ? Backend.diff-note
                            : (Backend.current-file == ""
                                ? "Select a changed file on the left to view its diff"
                                : "No textual changes to display");
                        color: Backend.gutter-fg;
                        horizontal-alignment: center;
                        font-size: 13px;
                    }
                }
                }  // content (diff list / empty state)
                }  // diff column VerticalLayout

                // Find-in-diff bar (Cmd/Ctrl-F): a top-right overlay on the diff.
                if Backend.show-find : Rectangle {
                    y: 8px;
                    x: parent.width - self.width - 12px;
                    width: 320px;
                    height: 38px;
                    background: Backend.panel-bg;
                    border-width: 1px;
                    border-color: Backend.divider;
                    border-radius: 6px;
                    HorizontalLayout {
                        padding: 6px;
                        spacing: 6px;
                        find-input := LineEdit {
                            placeholder-text: "Find in diff";
                            horizontal-stretch: 1;
                            init => { self.focus(); }
                            edited => { Backend.find(self.text); }
                            accepted => { Backend.find-next(); }
                        }
                        Text {
                            text: "\{Backend.find-current}/\{Backend.find-count}";
                            color: Backend.gutter-fg;
                            vertical-alignment: center;
                            font-size: 11px;
                        }
                        Button { text: "<"; clicked => { Backend.find-prev(); } }
                        Button { text: ">"; clicked => { Backend.find-next(); } }
                        Button {
                            text: "x";
                            clicked => {
                                Backend.show-find = false;
                                Backend.find-close();
                            }
                        }
                    }
                }

                // Floating affordance: appears when lines are selected inside a PR.
                // Opens the composer anchored to the selection.
                if Backend.pr-open && Backend.sel-anchor-row >= 0 && !Backend.composer-open : Rectangle {
                    y: parent.height - self.height - 14px;
                    x: parent.width / 2 - self.width / 2;
                    width: 190px;
                    height: 34px;
                    border-radius: 17px;
                    background: add-ta.has-hover ? Backend.selection : Backend.accent;
                    add-ta := TouchArea { clicked => { Backend.open-composer(false); } }
                    Text {
                        text: "Comment on selection";
                        color: Backend.on-accent;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Comment composer overlay (inline or whole-PR).
                if Backend.composer-open : Rectangle {
                    y: parent.height - self.height - 14px;
                    x: parent.width / 2 - self.width / 2;
                    width: min(560px, parent.width - 24px);
                    height: 138px;
                    background: Backend.panel-bg;
                    border-width: 1px;
                    border-color: Backend.divider;
                    border-radius: 8px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 8px;
                        Text {
                            text: Backend.composer-general
                                ? "New comment on the pull request"
                                : "New comment on " + Backend.composer-target;
                            color: Backend.gutter-fg;
                            font-size: 11px;
                            overflow: elide;
                        }
                        Rectangle {
                            vertical-stretch: 1;
                            background: Backend.bg;
                            border-width: 1px;
                            border-color: Backend.divider;
                            border-radius: 5px;
                            composer-input := TextInput {
                                x: 8px;
                                y: 6px;
                                width: parent.width - 16px;
                                height: parent.height - 12px;
                                color: Backend.fg;
                                font-family: Backend.mono-font;
                                font-size: 13px;
                                wrap: word-wrap;
                                single-line: false;
                                init => { self.focus(); }
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: end;
                            Text {
                                visible: Backend.posting-comment;
                                text: "Posting…";
                                color: Backend.gutter-fg;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                            Button {
                                text: "Cancel";
                                clicked => {
                                    Backend.composer-open = false;
                                    composer-input.text = "";
                                }
                            }
                            Button {
                                text: "Send";
                                clicked => {
                                    if (composer-input.text != "" && !Backend.posting-comment) {
                                        Backend.submit-comment(composer-input.text);
                                        composer-input.text = "";
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // status bar — neutral chrome (accent can resolve to white/very light
            // for some themes, which made this a blank white bar). Left section is
            // the general status message; the right section is reserved for network
            // activity (in-flight request count + an activity dot).
            Rectangle {
                height: 22px;
                background: Backend.panel-bg;
                Rectangle { y: 0; height: 1px; background: Backend.divider; }
                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;
                    Text {
                        text: Backend.status-text;
                        color: Backend.gutter-fg;
                        font-size: 11px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    Rectangle { width: 1px; background: Backend.divider; }
                    // Network section (right-aligned): activity dot + label + counts.
                    HorizontalLayout {
                        spacing: 6px;
                        property <bool> busy: Backend.net-active > 0 || Backend.net-prefetch > 0;
                        Rectangle {
                            width: 8px;
                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 7px;
                                    height: 7px;
                                    border-radius: 4px;
                                    background: Backend.net-active > 0 ? Backend.accent
                                        : (Backend.net-prefetch > 0 ? Backend.gutter-fg
                                                                    : Backend.divider);
                                }
                            }
                        }
                        Text {
                            // Foreground: "<label> (N)"; background-only: "Prefetching N";
                            // otherwise idle.
                            text: Backend.net-active > 0
                                ? ((Backend.net-label != "" ? Backend.net-label : "Working")
                                    + " (\{Backend.net-active})"
                                    + (Backend.net-prefetch > 0 ? " · \{Backend.net-prefetch} queued" : ""))
                                : (Backend.net-prefetch > 0
                                    ? "Prefetching \{Backend.net-prefetch}…"
                                    : "idle");
                            color: parent.busy ? Backend.accent : Backend.gutter-fg;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // RIGHT: commit-history panel + its resize handle (grows as it drags left).
        if !content.commits-collapsed : Rectangle {
            width: 6px;
            background: Backend.panel-bg;
            commits-handle := TouchArea {
                mouse-cursor: col-resize;
                moved => {
                    if (self.pressed) {
                        content.commits-width = clamp(
                            content.width - (self.absolute-position.x
                                - content.absolute-position.x + self.mouse-x) + 3px,
                            180px, content.width - 520px);
                    }
                }
            }
            Rectangle {
                x: 2px;
                width: 2px;
                background: commits-handle.pressed || commits-handle.has-hover
                            ? Backend.gutter-fg : transparent;
            }
        }
        if !content.commits-collapsed : CommitsPanel { panel-width: content.commits-width; }
        }
      }
    }

    // Periodic background refresh of the changes list (Slint has no focus event).
    Timer {
        interval: 5s;
        running: true;
        triggered => { Backend.auto-refresh(); }
    }

    // Settings overlay sits above everything.
    SettingsPanel {}
    BitbucketPanel {}

    // Discard confirmation (destructive — always confirm first).
    if Backend.confirm-discard != "" : Rectangle {
        background: #00000099;
        TouchArea { clicked => { Backend.confirm-discard = ""; } }
        Rectangle {
            width: 380px;
            height: 150px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Backend.panel-bg;
            border-radius: 10px;
            border-width: 1px;
            border-color: Backend.divider;
            TouchArea {}
            VerticalLayout {
                padding: 20px;
                spacing: 12px;
                Text { text: "Discard changes?"; color: Backend.fg; font-size: 16px; font-weight: 600; }
                Text {
                    text: Backend.confirm-discard;
                    color: Backend.gutter-fg;
                    font-size: 12px;
                    overflow: elide;
                }
                Text {
                    text: "This cannot be undone.";
                    color: #f48771;
                    font-size: 11px;
                }
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    Button { text: "Cancel"; clicked => { Backend.confirm-discard = ""; } }
                    Button {
                        text: "Discard";
                        clicked => {
                            Backend.discard-file(Backend.confirm-discard);
                            Backend.confirm-discard = "";
                        }
                    }
                }
            }
        }
    }

    // Create-branch name prompt (opened from a commit's context menu).
    if Backend.create-branch-oid != "" : Rectangle {
        background: #00000099;
        TouchArea { clicked => { Backend.create-branch-oid = ""; } }
        Rectangle {
            width: 380px;
            height: 156px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Backend.panel-bg;
            border-radius: 10px;
            border-width: 1px;
            border-color: Backend.divider;
            TouchArea {}
            VerticalLayout {
                padding: 20px;
                spacing: 12px;
                Text { text: "New branch"; color: Backend.fg; font-size: 16px; font-weight: 600; }
                branch-name := LineEdit {
                    placeholder-text: "branch name";
                    init => { self.focus(); }
                    accepted => {
                        Backend.create-branch(Backend.create-branch-oid, self.text);
                        Backend.create-branch-oid = "";
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    Button { text: "Cancel"; clicked => { Backend.create-branch-oid = ""; } }
                    Button {
                        text: "Create";
                        clicked => {
                            Backend.create-branch(Backend.create-branch-oid, branch-name.text);
                            Backend.create-branch-oid = "";
                        }
                    }
                }
            }
        }
    }
}
